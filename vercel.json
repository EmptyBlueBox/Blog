{
  "installCommand": "bun install --frozen-lockfile",
  "buildCommand": "bun run build",
  "crons": [],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; object-src 'none'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://cdn.jsdelivr.net https://unpkg.com https://umami.arthals.ink https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://api.github.com https://api.spencerwoo.com https://api.swo.moe https://umami.arthals.ink https://vitals.vercel-insights.com https://region1.google-analytics.com https://www.google-analytics.com https://waline.lyt0112.com; media-src 'self' blob: https:; frame-src https://www.youtube.com https://www.youtube-nocookie.com; manifest-src 'self'; worker-src 'self' blob:;"
        }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=2592000"
        }
      ]
    },
    {
      "source": "/((?!api/|_astro/|fonts/|favicon/|icons/|scripts/|.*\\..*).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=2592000"
        }
      ]
    },
    {
      "source": "/(.*\\.(?:html|xml|json))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=2592000"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/dextercap-rrd",
      "has": [
        {
          "type": "query",
          "key": "key",
          "value": "rubikscube"
        }
      ],
      "destination": "https://cdn.lyt0112.com/Projects/DexterCap/RubiksCube-363-391.rrd"
    },
    {
      "source": "/api/dextercap-rrd",
      "has": [
        {
          "type": "query",
          "key": "key",
          "value": "cuboid0"
        }
      ],
      "destination": "https://cdn.lyt0112.com/Projects/DexterCap/Cuboid_00-301-306.rrd"
    },
    {
      "source": "/api/dextercap-rrd",
      "has": [
        {
          "type": "query",
          "key": "key",
          "value": "cuboid1"
        }
      ],
      "destination": "https://cdn.lyt0112.com/Projects/DexterCap/Cuboid_01-551-556.rrd"
    },
    {
      "source": "/api/dextercap-rrd",
      "has": [
        {
          "type": "query",
          "key": "key",
          "value": "cuboid2"
        }
      ],
      "destination": "https://cdn.lyt0112.com/Projects/DexterCap/Cuboid_02-204-209.rrd"
    },
    {
      "source": "/api/dextercap-rrd",
      "has": [
        {
          "type": "query",
          "key": "key",
          "value": "cylinder"
        }
      ],
      "destination": "https://cdn.lyt0112.com/Projects/DexterCap/Cylinder-351-360.rrd"
    },
    {
      "source": "/api/dextercap-rrd",
      "has": [
        {
          "type": "query",
          "key": "key",
          "value": "plate"
        }
      ],
      "destination": "https://cdn.lyt0112.com/Projects/DexterCap/Plate-204-209.rrd"
    },
    {
      "source": "/api/dextercap-rrd",
      "has": [
        {
          "type": "query",
          "key": "key",
          "value": "prism"
        }
      ],
      "destination": "https://cdn.lyt0112.com/Projects/DexterCap/Prism-564-571.rrd"
    },
    {
      "source": "/api/dextercap-rrd",
      "has": [
        {
          "type": "query",
          "key": "key",
          "value": "ring"
        }
      ],
      "destination": "https://cdn.lyt0112.com/Projects/DexterCap/Ring-485-490.rrd"
    }
  ],
  "framework": "astro"
}
