---
import { socialLinks } from '@/data/social_links'
import PageLayout from '@/layouts/CommonPage.astro'
import { Image } from 'astro:assets'

import SocialLinksRow from '@/components/about/SocialLinksRow.astro'
import { Spoiler, Timeline } from '@/components/user'
import profile1 from '@/assets/about/profile_01.jpeg'
import profile2 from '@/assets/about/profile_02.jpeg'
import profile3 from '@/assets/about/profile_03.jpeg'
import profile4 from '@/assets/about/profile_04.jpeg'
import profile5 from '@/assets/about/profile_05.jpeg'
import profile6 from '@/assets/about/profile_06.jpeg'
import profile7 from '@/assets/about/profile_07.jpeg'

const allProfiles = [profile1, profile2, profile3, profile4, profile5, profile6, profile7]

const headings = [
  { depth: 2, slug: 'research', text: 'Current Research' },
  { depth: 2, slug: 'experience', text: 'Research Experience' },
  { depth: 2, slug: 'education', text: 'Education & Awards' },
  { depth: 2, slug: 'tools', text: 'Methods & Tools' },
  { depth: 2, slug: 'interests', text: 'Beyond Research' }
]

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'ProfilePage',
    url: new URL('/about', Astro.site).href,
    mainEntity: {
      '@type': 'Person',
      name: 'Yutong Liang',
      url: new URL('/about', Astro.site).href,
      image: allProfiles[0].src,
      sameAs: socialLinks.map((link) => link.href).filter((href) => href.startsWith('https://')),
      alumniOf: [
        {
          '@type': 'CollegeOrUniversity',
          name: 'University of California San Diego',
          url: 'https://cse.ucsd.edu'
        },
        {
          '@type': 'CollegeOrUniversity',
          name: 'Peking University',
          url: 'https://www.pku.edu.cn/'
        }
      ]
    }
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: new URL('/', Astro.site).href
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'About',
        item: new URL('/about', Astro.site).href
      }
    ]
  }
]
---

<PageLayout
  title='About'
  headings={headings}
  meta={{ imagePreview: 'large', structuredData, title: 'About' }}
>
  <h2 id='research'>Current Research</h2>

  <div class='about-content'>
    <div class='about-image-container not-prose'>
      <button
        id='profile-button'
        type='button'
        class='group block w-full cursor-pointer'
        aria-label='Show another profile photo'
      >
        <Image
          id='profile-image'
          data-profiles={JSON.stringify(allProfiles.map((profile) => profile.src))}
          src={allProfiles[0]}
          alt='Yutong Liang in front of a mountain landscape'
          loading='eager'
          quality='high'
          class='m-0 block w-full rounded-md transition-opacity duration-300 group-hover:opacity-90'
        />
      </button>
      <p class='image-caption'>
        <Spoiler>Click to switch photo.</Spoiler>
      </p>
    </div>

    <div class='about-copy'>
      <p>
        My work connects three problems: capturing dense human-object motion, learning dexterous
        hand manipulation from those motion, and training policies that generalize in the real
        world.
      </p>
      <p>
        I am especially interested in world models that learn how the physical world evolves, human
        demonstrations that provide scalable motion priors, and reinforcement learning that closes
        the final gap to dynamic, contact-rich control.
      </p>
    </div>
  </div>

  <SocialLinksRow links={socialLinks} />

  <h2 id='experience'>Research Experience</h2>
  <p>
    Across these roles, my focus progressed from representing human motion, to simulating physical
    interaction, to learning control policies that transfer to real robots.
  </p>
  <Timeline
    events={[
      {
        date: '2025 - Present',
        content:
          '<strong><a href="https://cse.ucsd.edu" target="_blank" rel="noopener noreferrer">UC San Diego</a></strong><br><span class="text-muted-foreground">Robot learning with <a href="https://xiaolonw.github.io" target="_blank" rel="noopener noreferrer">Prof. Xiaolong Wang</a></span>'
      },
      {
        date: '2023 - 2025',
        content:
          '<strong><a href="https://www.pku.edu.cn/" target="_blank" rel="noopener noreferrer">Peking University</a> · <a href="https://vcl.pku.edu.cn/" target="_blank" rel="noopener noreferrer">Visual Computing and Learning Lab</a></strong><br><span class="text-muted-foreground">Character animation and physics simulation on dexterous hands with <a href="https://libliu.info/" target="_blank" rel="noopener noreferrer">Prof. Libin Liu</a></span>'
      },
      {
        date: 'Summer 2024',
        content:
          '<strong><a href="https://www.stanford.edu/" target="_blank" rel="noopener noreferrer">Stanford University</a></strong><br><span class="text-muted-foreground">Research intern on human motion generation in the <a href="https://tml.stanford.edu/" target="_blank" rel="noopener noreferrer">TML Lab</a> and <a href="https://svl.stanford.edu/" target="_blank" rel="noopener noreferrer">SVL Lab</a> with <a href="https://shellguo.com/" target="_blank" rel="noopener noreferrer">Michelle Guo</a> and <a href="https://pei-xu.github.io/" target="_blank" rel="noopener noreferrer">Pei Xu</a>, guided by <a href="https://profiles.stanford.edu/c-karen-liu" target="_blank" rel="noopener noreferrer">Prof. Karen Liu</a> and <a href="https://jiajunwu.com/" target="_blank" rel="noopener noreferrer">Prof. Jiajun Wu</a></span>'
      },
      {
        date: '2022 - 2023',
        content:
          '<strong><a href="https://www.pku.edu.cn/" target="_blank" rel="noopener noreferrer">Peking University</a></strong><br><span class="text-muted-foreground">Data structures and network measurement with <a href="https://yangtonghome.github.io/" target="_blank" rel="noopener noreferrer">Prof. Tong Yang</a></span>'
      }
    ]}
  />

  <h2 id='education'>Education & Awards</h2>
  <h3>Education</h3>
  <Timeline
    events={[
      {
        date: '2025 - 2027',
        content:
          '<strong><a href="https://cse.ucsd.edu" target="_blank" rel="noopener noreferrer">University of California San Diego</a></strong><br><span class="text-muted-foreground">M.S. in Computer Science and Engineering</span>'
      },
      {
        date: '2021 - 2025',
        content:
          '<strong><a href="https://english.pku.edu.cn/" target="_blank" rel="noopener noreferrer">Peking University</a></strong><br><span class="text-muted-foreground">B.S. in Computer Science and Technology</span>'
      }
    ]}
  />

  <h3>Selected Awards</h3>
  <Timeline
    events={[
      {
        date: '2024',
        content:
          '<a href="https://www.pku.edu.cn" target="_blank" rel="noopener noreferrer">2024 PKU Scholarship, Top 5%</a>'
      },
      {
        date: '2024',
        content:
          '<a href="https://xgb.pku.edu.cn/xsjl/bjdxjl/82371.htm" target="_blank" rel="noopener noreferrer">2024 PKU Outstanding Research Award</a>'
      },
      {
        date: '2023',
        content:
          '<a href="https://www.pkuef.org/info/1133/3708.htm" target="_blank" rel="noopener noreferrer">2023 AEON Scholarship, Top 10%</a>'
      },
      {
        date: '2023',
        content:
          '<a href="https://xgb.pku.edu.cn/xsjl/bjdxjl/82371.htm" target="_blank" rel="noopener noreferrer">2023 PKU Merit Student</a>'
      },
      {
        date: '2022',
        content:
          '<a href="https://www.pkuef.org/info/1133/3717.htm" target="_blank" rel="noopener noreferrer">2022 Shenzhen Stock Exchange Scholarship, Top 20%</a>'
      },
      {
        date: '2022',
        content:
          '<a href="https://xgb.pku.edu.cn/xsjl/bjdxjl/82371.htm" target="_blank" rel="noopener noreferrer">2022 PKU Outstanding Academic Award</a>'
      },
      {
        date: '2021',
        content:
          '<a href="https://www.gotopku.cn/index/detail/1259.html" target="_blank" rel="noopener noreferrer">2021 PKU New Student Scholarship</a>'
      }
    ]}
  />

  <h2 id='tools'>Methods & Tools</h2>
  <p>
    I work mainly with Python, C++, PyTorch, Isaac Lab, MuJoCo, and real-world robot systems, using
    Rerun and Blender for visualization and Typst and LaTeX for technical writing.
  </p>

  <h2 id='interests'>Beyond Research</h2>
  <p>
    I am an enthusiastic speedcuber. My official personal bests include 9.47 seconds in 3×3 at Los
    Angeles 2024 and 2.36 seconds in Pyraminx at Sacramento 2024. Results are available on my <a
      href='https://www.worldcubeassociation.org/persons/2017LIAN26'
      class='hover:text-primary'
      target='_blank'
      rel='noopener noreferrer'>WCA profile</a
    >.
  </p>
  <p>
    I also write <a href="/tags/Rubik's%20Cube" class='hover:text-primary'>speedcubing tutorials</a> and
    personal essays about places, communities, and stories that stay with me.
  </p>
</PageLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const button = document.getElementById('profile-button') as HTMLButtonElement
    const image = document.getElementById('profile-image') as HTMLImageElement
    const profiles = JSON.parse(image.dataset.profiles!) as string[]
    let index = 0

    profiles.slice(1).forEach((src) => (new Image().src = src))
    button.addEventListener('click', () => {
      image.style.opacity = '0'
      setTimeout(() => {
        index = (index + 1) % profiles.length
        image.src = profiles[index]
        image.style.opacity = '1'
      }, 200)
    })
  })
</script>

<style>
  .about-content {
    display: grid;
    grid-template-columns: minmax(0, 250px) minmax(0, 1fr);
    gap: 1.25rem;
    align-items: start;
  }

  .about-image-container {
    width: 100%;
  }

  .image-caption {
    margin-top: 0.5rem;
    text-align: center;
    font-style: italic;
    font-size: 0.9rem;
  }

  .about-copy > :first-child {
    margin-top: 0;
  }

  @media (max-width: 640px) {
    .about-content {
      grid-template-columns: 1fr;
    }

    .about-image-container {
      max-width: 280px;
      margin: 0 auto;
    }
  }
</style>
