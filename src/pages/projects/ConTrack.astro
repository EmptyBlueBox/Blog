---
import Analytics from '@vercel/analytics/astro'
import SpeedInsights from '@vercel/speed-insights/astro'

import BaseHead from '@/components/BaseHead.astro'
import ThemeProvider from '@/components/layout/ThemeProvider.astro'
import teaserImage from '@/assets/projects/contrack/teaser.jpg'

import '@/assets/styles/app.css'

export const prerender = true

const title = 'ConTrack: Constrained Hand Motion Tracking with Adaptive Trade-off Control'
const description =
  'ConTrack learns robot policies that execute contact-rich human hand-object demonstrations across different hands.'
const cdn = 'https://cdn.lyt0112.com/Projects/ConTrack/'

const authors = [
  { name: 'Yutong Liang', href: 'https://www.lyt0112.com' },
  { name: 'Quanquan Peng', href: 'https://bariona.github.io/' },
  { name: 'Ri-Zhao Qiu', href: 'https://rogerqi.github.io/' },
  { name: 'Xiaolong Wang', href: 'https://xiaolonw.github.io/' }
]

const links = [
  { label: 'Paper Coming Soon', href: '#' },
  { label: 'Code Coming Soon', href: '#' },
  { label: 'X Post Coming Soon', href: '#' }
]

const overviewIntro =
  'ConTrack starts from human hand-object motion data and learns robot policies that reproduce the demonstrated object motion in simulation and on hardware.'

const overviewPoints = [
  'Directly retargeting human fingers to a robot hand can break contact because the two hands have different shapes, joints, and reachable grasps.',
  'ConTrack treats object pose tracking as the main task, so the robot may change its hand motion when exact imitation would make the object drift.',
  'Hand motion and contact are still supervised as style cues, which keeps the interaction close to the human demonstration.',
  'The same RL recipe is used to train one policy per clip across GRAB, ARCTIC, DexterHand, and two robot hands without per-sequence reward tuning.'
]

const simGroups = [
  {
    name: 'GRAB',
    videos: [
      [
        'Cube Handover, XHand',
        'xhand_sim_video-720p/grab-s1_cubemedium_offhand_1-xarm7_xhand-180_540-render-720p.mp4'
      ],
      [
        'Cube Handover, SHARPA',
        'sharpa_sim_video-720p/grab-s1_cubemedium_offhand_1-rby1a_sharpa-180_540-render-720p.mp4'
      ],
      [
        'Cylinder Handover, XHand',
        'xhand_sim_video-720p/grab-s1_cylindermedium_offhand_1-xarm7_xhand-268_628-render-720p.mp4'
      ],
      [
        'Cylinder Handover, SHARPA',
        'sharpa_sim_video-720p/grab-s1_cylindermedium_offhand_1-rby1a_sharpa-268_628-render-720p.mp4'
      ],
      [
        'Hammer Use, XHand',
        'xhand_sim_video-720p/grab-s1_hammer_use_1-xarm7_xhand-120_840-render-720p.mp4'
      ],
      [
        'Hammer Use, SHARPA',
        'sharpa_sim_video-720p/grab-s1_hammer_use_1-rby1a_sharpa-120_840-render-720p.mp4'
      ],
      [
        'Waterbottle Handover, XHand',
        'xhand_sim_video-720p/grab-s1_waterbottle_offhand_1-xarm7_xhand-24_504-render-720p.mp4'
      ],
      [
        'Waterbottle Handover, SHARPA',
        'sharpa_sim_video-720p/grab-s1_waterbottle_offhand_1-rby1a_sharpa-24_504-render-720p.mp4'
      ],
      [
        'Wineglass Handover, XHand',
        'xhand_sim_video-720p/grab-s1_wineglass_offhand_1-xarm7_xhand-156_516-render-720p.mp4'
      ],
      [
        'Wineglass Handover, SHARPA',
        'sharpa_sim_video-720p/grab-s1_wineglass_offhand_1-rby1a_sharpa-156_516-render-720p.mp4'
      ]
    ]
  },
  {
    name: 'ARCTIC',
    videos: [
      [
        'Box Use, XHand',
        'xhand_sim_video-720p/arctic-s01_box_use_01-xarm7_xhand-117_240-render-720p.mp4'
      ],
      [
        'Box Use, SHARPA',
        'sharpa_sim_video-720p/arctic-s01_box_use_01-rby1a_sharpa-117_240-render-720p.mp4'
      ],
      [
        'Mixer Use, XHand',
        'xhand_sim_video-720p/arctic-s01_mixer_use_01-xarm7_xhand-45_345-render-720p.mp4'
      ],
      [
        'Mixer Use, SHARPA',
        'sharpa_sim_video-720p/arctic-s01_mixer_use_01-rby1a_sharpa-45_345-render-720p.mp4'
      ],
      [
        'Notebook Use, XHand',
        'xhand_sim_video-720p/arctic-s01_notebook_use_01-xarm7_xhand-180_270-render-720p.mp4'
      ],
      [
        'Notebook Use, SHARPA',
        'sharpa_sim_video-720p/arctic-s01_notebook_use_01-rby1a_sharpa-180_270-render-720p.mp4'
      ],
      [
        'Waffleiron Use, XHand',
        'xhand_sim_video-720p/arctic-s01_waffleiron_use_01-xarm7_xhand-75_195-render-720p.mp4'
      ],
      [
        'Waffleiron Use, SHARPA',
        'sharpa_sim_video-720p/arctic-s01_waffleiron_use_01-rby1a_sharpa-75_195-render-720p.mp4'
      ]
    ]
  },
  {
    name: 'DexterHand',
    videos: [
      [
        'Cuboid 0 Manipulation, XHand',
        'xhand_sim_video-720p/dexterhand-Cuboid_00-fps_20-xarm7_xhand-5880_5940-render-720p.mp4'
      ],
      [
        'Cuboid 0 Manipulation, SHARPA',
        'sharpa_sim_video-720p/dexterhand-Cuboid_00-fps_20-rby1a_sharpa-5880_5940-render-720p.mp4'
      ],
      [
        'Cuboid 1 Manipulation, XHand',
        'xhand_sim_video-720p/dexterhand-Cuboid_01-fps_20-xarm7_xhand-7824_7864-render-720p.mp4'
      ],
      [
        'Cuboid 1 Manipulation, SHARPA',
        'sharpa_sim_video-720p/dexterhand-Cuboid_01-fps_20-rby1a_sharpa-7824_7864-render-720p.mp4'
      ],
      [
        'Cylinder Manipulation, XHand',
        'xhand_sim_video-720p/dexterhand-Cylinder_00-fps_20-xarm7_xhand-3600_3700-render-720p.mp4'
      ],
      [
        'Cylinder Manipulation, SHARPA',
        'sharpa_sim_video-720p/dexterhand-Cylinder_00-fps_20-rby1a_sharpa-3600_3700-render-720p.mp4'
      ],
      [
        'Ring Manipulation, XHand',
        'xhand_sim_video-720p/dexterhand-Ring_00-fps_20-xarm7_xhand-10240_10340-render-720p.mp4'
      ],
      [
        'Ring Manipulation, SHARPA',
        'sharpa_sim_video-720p/dexterhand-Ring_00-fps_20-rby1a_sharpa-10240_10340-render-720p.mp4'
      ]
    ]
  }
]

const realVideos = [
  [
    'Cylinder Handover, real XHand',
    'real-8x-sdr-720p/grab-s1_cylindermedium_offhand_1-xarm7_xhand-268_628_8x_sdr-720p.mp4'
  ],
  [
    'Hammer Use, real XHand',
    'real-8x-sdr-720p/grab-s1_hammer_use_1-xarm7_xhand-120_840_8x_sdr-720p.mp4'
  ],
  [
    'Cube Manipulation, real XHand',
    'real-8x-sdr-720p/grab-s2_cubemedium_inspect_1-xarm7_xhand-192_672_8x_sdr-720p.mp4'
  ]
]

const bibtex = `@misc{liang2026contrack,
      title={ConTrack: Constrained Hand Motion Tracking with Adaptive Trade-off Control}, 
      author={Liang, Yutong and Peng, Quanquan and Qiu, Ri-Zhao and Wang, Xiaolong},
      year={2026},
      eprint={xxxx.xxxxx},
      archivePrefix={arXiv},
      primaryClass={cs.RO},
      url={https://arxiv.org/abs/xxxx.xxxxx}, 
}`

const approachIntro =
  'The method separates task success from motion style. Task success means object pose tracking. Motion style means robot joint motion, contact timing, and contact locations inherited from the human demonstration.'

const approachSteps = [
  {
    title: 'Start near the human motion',
    text: 'A retargeted human hand trajectory gives the robot an initial joint reference. The policy controls residual joint targets around this reference, so it can follow the human motion while correcting for contact dynamics.'
  },
  {
    title: 'Keep the object on track',
    text: 'Object pose tracking is the task that must stay above a target quality. When exact hand imitation causes the object to drift, the policy can change the robot hand motion.'
  },
  {
    title: 'Adapt the task-style balance',
    text: 'Training monitors object tracking. If the object falls behind, more learning pressure goes to object motion. After object tracking improves, training shifts capacity back to hand motion and contacts.'
  },
  {
    title: 'Train near the failure boundary',
    text: 'Long clips are difficult because early failures stop the policy from practicing later contacts. ConTrack stores states the policy has reached, restarts near the current failure point, and moves those restarts earlier as the policy improves.'
  },
  {
    title: 'Use contact priors',
    text: 'Many hand motions can move the same object. Human contact timing and contact locations guide each robot link toward the demonstrated interaction pattern.'
  }
]
---

<html lang='en-US'>
  <head>
    <BaseHead
      title='ConTrack'
      description={description}
      canonical='/projects/ConTrack'
      ogImage={teaserImage.src}
    />
    <ThemeProvider />
  </head>
  <body class='contrack-body'>
    <main class='page'>
      <header class='hero'>
        <h1>{title}</h1>
        <p class='authors'>
          {
            authors.map((author, index) => (
              <>
                <a
                  href={author.href}
                  target={author.href === '#' ? undefined : '_blank'}
                  rel={author.href === '#' ? undefined : 'noopener noreferrer'}
                >
                  {author.name}
                </a>
                {index < authors.length - 1 && <span>, </span>}
              </>
            ))
          }
        </p>
        <p class='affiliations'>University of California San Diego</p>
        <p class='links'>
          {
            links.map((link) => (
              <a
                href={link.href}
                target={link.href === '#' ? undefined : '_blank'}
                rel={link.href === '#' ? undefined : 'noopener noreferrer'}
              >
                {link.label}
              </a>
            ))
          }
        </p>
      </header>

      <figure class='teaser'>
        <img src={teaserImage.src} alt='ConTrack overview teaser.' />
      </figure>

      <section>
        <h2>Overview</h2>
        <p>{overviewIntro}</p>
        <ul class='overview-list'>
          {overviewPoints.map((point) => <li>{point}</li>)}
        </ul>
      </section>

      <section>
        <h2>Video</h2>
        <iframe
          class='main-video'
          src='https://www.youtube.com/embed/Rr96tHf0ZUU'
          title='ConTrack video'
          allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share'
          allowfullscreen></iframe>
      </section>

      <section>
        <h2>Approach</h2>
        <p>{approachIntro}</p>
        <ul class='method-steps'>
          {
            approachSteps.map((step) => (
              <li>
                <div>
                  <strong>{step.title}</strong>
                  <span>{step.text}</span>
                </div>
              </li>
            ))
          }
        </ul>
      </section>

      <section>
        <h2>Experiment</h2>
        <p>
          We test ConTrack on bimanual object manipulation, articulated tool use, and in-hand rotation.
          The videos below show one policy per clip trained with the same recipe across different
          datasets and robot hands.
        </p>

        <h3>Simulation Videos</h3>
        {
          simGroups.map((group) => (
            <div class='sim-group'>
              <h4>{group.name}</h4>
              <div class='video-grid'>
                {group.videos.map(([name, src]) => (
                  <figure>
                    <video
                      class='lazy-video'
                      muted
                      loop
                      playsinline
                      autoplay
                      preload='none'
                      data-src={`${cdn}${src}`}
                    />
                    <figcaption>{name}</figcaption>
                  </figure>
                ))}
              </div>
            </div>
          ))
        }

        <h3>Real Robot Videos</h3>
        <div class='real-grid'>
          {
            realVideos.map(([name, src]) => (
              <figure>
                <video
                  class='lazy-video'
                  muted
                  loop
                  playsinline
                  autoplay
                  preload='none'
                  data-src={`${cdn}${src}`}
                />
                <figcaption>{name}</figcaption>
              </figure>
            ))
          }
        </div>
      </section>

      <section>
        <h2>BibTeX</h2>
        <pre><code>{bibtex}</code></pre>
      </section>
    </main>
    <script>
      const videos = [...document.querySelectorAll('video.lazy-video')] as HTMLVideoElement[]
      const loadVideo = (video: HTMLVideoElement) => {
        const src = video.dataset.src
        if (!src || video.src) return
        video.preload = 'auto'
        video.src = src
        video.load()
        video.play().catch(() => {})
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const video = entry.target as HTMLVideoElement
            if (entry.isIntersecting) {
              loadVideo(video)
              video.play().catch(() => {})
            } else {
              video.pause()
            }
          })
        },
        { rootMargin: '360px 0px', threshold: 0.08 }
      )

      videos.forEach((video) => observer.observe(video))
    </script>
    <Analytics />
    <SpeedInsights />
  </body>
</html>

<style>
  :global(body.contrack-body) {
    --contrack-bg: #fff;
    --contrack-text: #111;
    --contrack-muted: #555;
    --contrack-link: #1f5fae;
    --contrack-button-border: #d8d8d8;
    --contrack-button-hover: #f7f7f4;
    --contrack-button-ink: #171717;
    --contrack-line: #ddd;
    --contrack-code-bg: #f7f7f7;
    --contrack-video-bg: #000;
    margin: 0;
    background: var(--contrack-bg);
    color: var(--contrack-text);
  }

  :global(html.dark body.contrack-body) {
    --contrack-bg: #0b0b10;
    --contrack-text: #e8e8ee;
    --contrack-muted: #a6a6b3;
    --contrack-link: #8ab4ff;
    --contrack-button-border: #3a3a45;
    --contrack-button-hover: #15151c;
    --contrack-button-ink: #ededf3;
    --contrack-line: #31313a;
    --contrack-code-bg: #17171f;
  }

  .page {
    width: min(980px, calc(100% - 32px));
    margin: 0 auto;
    padding: 48px 0 72px;
    font-size: 16px;
    line-height: 1.62;
  }

  .hero {
    text-align: center;
  }

  h1 {
    max-width: 900px;
    margin: 0 auto 18px;
    font-size: clamp(2rem, 5vw, 3.4rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .authors,
  .affiliations,
  .links {
    margin: 6px 0;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    margin-top: 18px;
  }

  .authors {
    font-size: 1.08rem;
  }

  .affiliations,
  .muted {
    color: var(--contrack-muted);
  }

  a {
    color: var(--contrack-link);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  .links a {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    border: 1px solid var(--contrack-button-border);
    border-radius: 2px;
    background: transparent;
    padding: 0 13px;
    color: var(--contrack-button-ink);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono',
      'Courier New', monospace;
    font-size: 0.78rem;
    font-weight: 500;
    line-height: 1.2;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      transform 160ms ease;
  }

  .links a:hover {
    background: var(--contrack-button-hover);
    border-color: var(--contrack-text);
    text-decoration: none;
    transform: translateY(-1px);
  }

  .teaser {
    margin: 34px 0 46px;
  }

  .teaser img {
    display: block;
    width: 100%;
  }

  section {
    margin-top: 52px;
  }

  h2 {
    margin: 0 0 18px;
    border-bottom: 1px solid var(--contrack-line);
    padding-bottom: 6px;
    font-size: 1.65rem;
    font-weight: 700;
    letter-spacing: 0;
  }

  h3 {
    margin: 30px 0 10px;
    font-size: 1.08rem;
    font-weight: 700;
    letter-spacing: 0;
  }

  h4 {
    margin: 18px 0 10px;
    font-size: 1rem;
    font-weight: 700;
  }

  p {
    margin: 0 0 16px;
  }

  .overview-list {
    margin: 8px 0 0;
    padding-left: 0;
    list-style: none;
  }

  .overview-list li {
    position: relative;
    margin: 8px 0;
    padding-left: 1.1rem;
  }

  .overview-list li::before {
    position: absolute;
    top: 0.72em;
    left: 0;
    width: 0.34rem;
    height: 0.34rem;
    border-radius: 50%;
    background: var(--contrack-text);
    content: '';
  }

  video {
    display: block;
    width: 100%;
    background: var(--contrack-video-bg);
  }

  .main-video {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
    background: var(--contrack-video-bg);
  }

  .method-steps {
    display: grid;
    gap: 14px;
    margin: 6px 0 0;
    padding: 0;
    list-style: none;
  }

  .method-steps li {
    border-top: 1px solid var(--contrack-line);
    padding-top: 14px;
  }

  .method-steps li:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .method-steps strong {
    display: block;
    margin-bottom: 2px;
  }

  .method-steps span {
    display: block;
    color: var(--contrack-muted);
  }

  strong {
    font-weight: 800;
  }

  .sim-group {
    margin-top: 18px;
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  .real-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  figure {
    margin: 0;
  }

  .video-grid video,
  .real-grid video {
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  figcaption {
    margin-top: 5px;
    color: var(--contrack-muted);
    font-size: 0.86rem;
    line-height: 1.3;
  }

  pre {
    overflow-x: auto;
    margin: 0;
    background: var(--contrack-code-bg);
    padding: 14px 16px;
    font-size: 0.9rem;
    line-height: 1.55;
  }

  @media (max-width: 860px) {
    .video-grid,
    .real-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .page {
      width: min(100% - 24px, 980px);
      padding-top: 32px;
    }

    .video-grid,
    .real-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
