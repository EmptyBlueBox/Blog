---
import Analytics from '@vercel/analytics/astro'
import SpeedInsights from '@vercel/speed-insights/astro'
import katex from 'katex'

import BaseHead from '@/components/BaseHead.astro'
import ThemeProvider from '@/components/layout/ThemeProvider.astro'
import teaserImage from '@/assets/projects/contrack/teaser.jpg'

import '@/assets/styles/app.css'
import 'katex/dist/katex.min.css'

export const prerender = true

const title = 'ConTrack: Constrained Hand Motion Tracking with Adaptive Trade-off Control'
const description =
  'ConTrack turns contact-rich human demonstrations into executable dexterous robot motions.'
const cdn = 'https://cdn.lyt0112.com/Projects/ConTrack/'

const authors = [
  { name: 'Yutong Liang', href: 'https://www.lyt0112.com' },
  { name: 'Quanquan Peng', href: 'https://bariona.github.io/' },
  { name: 'Ri-Zhao Qiu', href: 'https://rogerqi.github.io/' },
  { name: 'Xiaolong Wang', href: 'https://xiaolonw.github.io/' }
]

const links = [
  { label: 'Paper (Coming Soon)', href: '#' },
  { label: 'Code (Coming Soon)', href: '#' },
  { label: 'X Post (Coming Soon)', href: '#' }
]

const overviewIntro =
  'ConTrack follows one rule: keep the object on track, and let the robot hand shift when exact human imitation is not executable.'

const overviewPoints = [
  'Human and robot hands have different kinematics, so finger-perfect retargeting often breaks contact-rich tasks.',
  'ConTrack makes object tracking a constraint, then uses the remaining freedom for joint motion, contact timing, and contact locations.',
  'The same RL recipe works across multiple datasets, hands, and real execution without per-clip reward tuning.'
]

const metricHeaders = [
  'Method / Group',
  'Progress ↑',
  'Obj pos (m) ↓',
  'Obj rot (rad) ↓',
  'Finger err (rad) ↓',
  'Contact F1 ↑',
  'Contact pt (m) ↓'
]

const baselineRows = [
