import '@/assets/styles/app.css'

export const prerender = true

const title = 'ConTrack: Constrained Hand Motion Tracking with Adaptive Trade-off Control'
const description =
  'ConTrack learns robot policies that execute contact-rich human hand-object demonstrations across different hands.'
const cdn = 'https://cdn.lyt0112.com/Projects/ConTrack/'

const authors = [
  { name: 'Yutong Liang', href: 'https://www.lyt0112.com' },
  { name: 'Quanquan Peng', href: 'https://bariona.github.io/' },
  { name: 'Ri-Zhao Qiu', href: 'https://rogerqi.github.io/' },
  { name: 'Xiaolong Wang', href: 'https://xiaolonw.github.io/' }
]

const links = [
  { label: 'Paper (Coming Soon)', href: '#' },
  { label: 'Code (Coming Soon)', href: '#' },
  { label: 'X Post (Coming Soon)', href: '#' }
]

const overviewIntro =
  'ConTrack is a reinforcement learning framework that turns contact-rich human hand-object demonstrations into robot motions.'

const overviewPoints = [
  'Human and robot hands differ in shape and joints, so copying the exact hand pose is the wrong target.',
  'What the demonstration really specifies is how the object moves, so ConTrack tracks the object motion as the task and lets the robot hand deviate from the human hand to find its own way to reproduce it.'
]

const simGroups = [
  {
    name: 'GRAB',
