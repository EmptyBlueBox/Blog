---
import Analytics from '@vercel/analytics/astro'
import SpeedInsights from '@vercel/speed-insights/astro'

import BaseHead from '@/components/BaseHead.astro'
import ThemeProvider from '@/components/layout/ThemeProvider.astro'
import Button from '@/components/user/Button.astro'
import teaserImage from '@/assets/projects/contrack/teaser.jpg'
import teaserVideo from '@/assets/projects/covers/contrack_teaser-720p.mp4'

import '@/assets/styles/app.css'

export const prerender = true

const title = 'ConTrack: Constrained Hand Motion Tracking with Adaptive Trade-off Control'
const description =
  'ConTrack learns robot policies that execute contact-rich human hand-object demonstrations across different hands.'
const cdn = 'https://cdn.lyt0112.com/Projects/ConTrack/'

const authors = [
  { name: 'Yutong Liang', href: 'https://www.lyt0112.com' },
  { name: 'Quanquan Peng', href: 'https://bariona.github.io/' },
  { name: 'Ri-Zhao Qiu', href: 'https://rogerqi.github.io/' },
  { name: 'Xiaolong Wang', href: 'https://xiaolonw.github.io/' }
]

const links = [
  { label: 'Paper', href: 'https://arxiv.org/abs/2606.03177' },
  { label: 'Code', href: 'https://github.com/EmptyBlueBox/ConTrack' },
  { label: 'X Post', href: 'https://x.com/YutongLiang_/status/2062212378721419371' }
]

const overviewIntro =
  'ConTrack is a reinforcement learning framework that turns contact-rich human hand-object demonstrations into robot motions.'

const overviewPoints = [
  'Human and robot hands differ in shape and joints, so copying the exact hand pose is the wrong target.',
  'What the demonstration really specifies is how the object moves.',
  'ConTrack tracks the object motion as the task and lets the robot hand deviate from the human hand to find its own way to complete the task.'
]

const simGroups = [
  {
    name: 'GRAB Dataset',
    videos: [
      [
        'Cube Handover, XHand',
        'xhand_sim_video-720p/grab-s1_cubemedium_offhand_1-xarm7_xhand-180_540-render-720p.mp4'
      ],
      [
        'Cube Handover, Sharpa Wave',
        'sharpa_sim_video-720p/grab-s1_cubemedium_offhand_1-rby1a_sharpa-180_540-render-720p.mp4'
      ],
      [
        'Hammer Use, XHand',
        'xhand_sim_video-720p/grab-s1_hammer_use_1-xarm7_xhand-120_840-render-720p.mp4'
      ],
      [
        'Hammer Use, Sharpa Wave',
        'sharpa_sim_video-720p/grab-s1_hammer_use_1-rby1a_sharpa-120_840-render-720p.mp4'
      ],
      [
        'Waterbottle Handover, XHand',
        'xhand_sim_video-720p/grab-s1_waterbottle_offhand_1-xarm7_xhand-24_504-render-720p.mp4'
      ],
      [
        'Waterbottle Handover, Sharpa Wave',
        'sharpa_sim_video-720p/grab-s1_waterbottle_offhand_1-rby1a_sharpa-24_504-render-720p.mp4'
      ],
      [
        'Wineglass Handover, XHand',
        'xhand_sim_video-720p/grab-s1_wineglass_offhand_1-xarm7_xhand-156_516-render-720p.mp4'
      ],
      [
        'Wineglass Handover, Sharpa Wave',
        'sharpa_sim_video-720p/grab-s1_wineglass_offhand_1-rby1a_sharpa-156_516-render-720p.mp4'
      ]
    ]
  },
  {
    name: 'ARCTIC Dataset',
    videos: [
      [
        'Box Use, XHand',
        'xhand_sim_video-720p/arctic-s01_box_use_01-xarm7_xhand-117_240-render-720p.mp4'
      ],
      [
        'Box Use, Sharpa Wave',
        'sharpa_sim_video-720p/arctic-s01_box_use_01-rby1a_sharpa-117_240-render-720p.mp4'
      ],
      [
        'Mixer Use, XHand',
        'xhand_sim_video-720p/arctic-s01_mixer_use_01-xarm7_xhand-45_345-render-720p.mp4'
      ],
      [
        'Mixer Use, Sharpa Wave',
        'sharpa_sim_video-720p/arctic-s01_mixer_use_01-rby1a_sharpa-45_345-render-720p.mp4'
      ],
      [
        'Notebook Use, XHand',
        'xhand_sim_video-720p/arctic-s01_notebook_use_01-xarm7_xhand-180_270-render-720p.mp4'
      ],
      [
        'Notebook Use, Sharpa Wave',
        'sharpa_sim_video-720p/arctic-s01_notebook_use_01-rby1a_sharpa-180_270-render-720p.mp4'
      ],
      [
        'Waffleiron Use, XHand',
        'xhand_sim_video-720p/arctic-s01_waffleiron_use_01-xarm7_xhand-75_195-render-720p.mp4'
      ],
      [
        'Waffleiron Use, Sharpa Wave',
        'sharpa_sim_video-720p/arctic-s01_waffleiron_use_01-rby1a_sharpa-75_195-render-720p.mp4'
      ]
    ]
  },
  {
    name: 'DexterHand Dataset',
    videos: [
      [
        'Cuboid 0 Manipulation, XHand',
        'xhand_sim_video-720p/dexterhand-Cuboid_00-fps_20-xarm7_xhand-5880_5940-render-720p.mp4'
      ],
      [
        'Cuboid 0 Manipulation, Sharpa Wave',
        'sharpa_sim_video-720p/dexterhand-Cuboid_00-fps_20-rby1a_sharpa-5880_5940-render-720p.mp4'
      ],
      [
        'Cuboid 1 Manipulation, XHand',
        'xhand_sim_video-720p/dexterhand-Cuboid_01-fps_20-xarm7_xhand-7824_7864-render-720p.mp4'
      ],
      [
        'Cuboid 1 Manipulation, Sharpa Wave',
        'sharpa_sim_video-720p/dexterhand-Cuboid_01-fps_20-rby1a_sharpa-7824_7864-render-720p.mp4'
      ],
      [
        'Cylinder Manipulation, XHand',
        'xhand_sim_video-720p/dexterhand-Cylinder_00-fps_20-xarm7_xhand-3600_3700-render-720p.mp4'
      ],
      [
        'Cylinder Manipulation, Sharpa Wave',
        'sharpa_sim_video-720p/dexterhand-Cylinder_00-fps_20-rby1a_sharpa-3600_3700-render-720p.mp4'
      ],
      [
        'Ring Manipulation, XHand',
        'xhand_sim_video-720p/dexterhand-Ring_00-fps_20-xarm7_xhand-10240_10340-render-720p.mp4'
      ],
      [
        'Ring Manipulation, Sharpa Wave',
        'sharpa_sim_video-720p/dexterhand-Ring_00-fps_20-rby1a_sharpa-10240_10340-render-720p.mp4'
      ]
    ]
  }
]

const realVideos = [
  [
    'Cylinder Handover, real XHand',
    'real-8x-sdr-720p/grab-s1_cylindermedium_offhand_1-xarm7_xhand-268_628_8x_sdr-720p.mp4'
  ],
  [
    'Hammer Use, real XHand',
    'real-8x-sdr-720p/grab-s1_hammer_use_1-xarm7_xhand-120_840_8x_sdr-720p.mp4'
  ],
  [
    'Cube Manipulation, real XHand',
    'real-8x-sdr-720p/grab-s2_cubemedium_inspect_1-xarm7_xhand-192_672_8x_sdr-720p.mp4'
  ]
]

const bibtex = `@article{liang2026contrack,
      title={ConTrack: Constrained Hand Motion Tracking with Adaptive Trade-off Control}, 
      author={Yutong Liang and Quanquan Peng and Ri-Zhao Qiu and Xiaolong Wang},
      journal={arXiv preprint arXiv:2606.03177},
      year={2026}
}`

const approachIntro =
  'ConTrack uses object motion as the task target, then spends the remaining learning capacity on hand motion and contact style.'

const approachSteps = [
  {
    title: 'Track the object, leave the hand free',
    text: 'ConTrack keeps the object close to the reference while allowing the robot hand to use a motion that fits its own kinematics.'
  },
  {
    title: 'Balance the task-style trade-off online',
    text: 'ConTrack uses a scalar controller that compares current object-tracking return with the best return reached on the clip. When tracking falls below the target ratio, training shifts weight to the object; after recovery, capacity moves back to style.'
  },
  {
    title: 'Practice from reachable failures',
    text: 'ConTrack samples resets near early failure boundaries, so the policy practices reachable contact phases more often. During training, the recent failure boundary gradually moves earlier to the start.'
  },
  {
    title: 'Shape the contact pattern',
    text: 'Many robot trajectories can support the same object motion, and not all of them touch the object well. ConTrack uses reference contact events and object-local contact points to encourage more natural contact-rich motion.'
  }
]
---

<html lang='en-US'>
  <head>
    <BaseHead
      title='ConTrack'
      description={description}
      canonical='/projects/ConTrack'
      ogImage={teaserImage.src}
    />
    <script is:inline async src='https://www.googletagmanager.com/gtag/js?id=G-TZ8JVZJ6BM'></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || []
      function gtag() {
        window.dataLayer.push(arguments)
      }
      gtag('js', new Date())
      gtag('config', 'G-TZ8JVZJ6BM', { send_page_view: true, transport_type: 'beacon' })
    </script>
    <script
      is:inline
      defer
      src='https://umami.arthals.ink/script.js'
      data-website-id='214f27d3-33cd-40c6-828a-814a4b1716b8'></script>
    <ThemeProvider />
  </head>
  <body class='contrack-body'>
    <main class='page'>
      <header class='hero'>
        <h1>{title}</h1>
        <p class='authors'>
          {
            authors.map((author, index) => (
              <>
                <a
                  href={author.href}
                  class='text-foreground no-underline transition-colors hover:text-primary hover:no-underline'
                  target={author.href === '#' ? undefined : '_blank'}
                  rel={author.href === '#' ? undefined : 'noopener noreferrer'}
                >
                  {author.name}
                </a>
                {index < authors.length - 1 && <span>, </span>}
              </>
            ))
          }
        </p>
        <p class='affiliations'>University of California San Diego</p>
        <div class='links'>
          {
            links.map((link) => (
              <Button
                title={link.label}
                href={link.href}
                style='pill'
                class='px-3 py-1.5 text-base'
                target={link.href === '#' ? undefined : '_blank'}
                rel={link.href === '#' ? undefined : 'noopener noreferrer'}
              />
            ))
          }
        </div>
      </header>

      <figure class='teaser'>
        <video src={teaserVideo} muted loop playsinline autoplay preload='auto'></video>
      </figure>

      <section>
        <h2>Overview</h2>
        <p>{overviewIntro}</p>
        <ul class='overview-list'>
          {overviewPoints.map((point) => <li>{point}</li>)}
        </ul>
      </section>

      <section>
        <h2>Video</h2>
        <iframe
          class='main-video'
          src='https://www.youtube.com/embed/Rr96tHf0ZUU'
          title='ConTrack video'
          allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share'
          allowfullscreen></iframe>
      </section>

      <section>
        <h2>Results</h2>
        <p>
          We test ConTrack on bimanual object manipulation (GRAB Dataset), articulated tool use
          (ARCTIC Dataset), and in-hand rotation (DexterHand Dataset). Each video below is one
          policy per clip, trained with the same recipe and shown on both the XHand and Sharpa Wave
          robot hands.
        </p>

        <h3>Real Robot Videos</h3>
        <div class='real-grid'>
          {
            realVideos.map(([name, src]) => (
              <figure>
                <video
                  class='lazy-video'
                  muted
                  loop
                  playsinline
                  autoplay
                  preload='none'
                  data-src={`${cdn}${src}`}
                />
                <figcaption>{name}</figcaption>
              </figure>
            ))
          }
        </div>

        <h3>Simulation Videos</h3>
        {
          simGroups.map((group) => (
            <div class='sim-group'>
              <h4>{group.name}</h4>
              <div class='video-grid'>
                {group.videos.map(([name, src]) => (
                  <figure>
                    <video
                      class='lazy-video'
                      muted
                      loop
                      playsinline
                      autoplay
                      preload='none'
                      data-src={`${cdn}${src}`}
                    />
                    <figcaption>{name}</figcaption>
                  </figure>
                ))}
              </div>
            </div>
          ))
        }
      </section>

      <section>
        <h2>Method</h2>
        <p>{approachIntro}</p>
        <ul class='method-steps'>
          {
            approachSteps.map((step) => (
              <li>
                <div>
                  <strong>{step.title}</strong>
                  <span>{step.text}</span>
                </div>
              </li>
            ))
          }
        </ul>
      </section>

      <section>
        <h2>BibTeX</h2>
        <pre><code>{bibtex}</code></pre>
      </section>
    </main>
    <script>
      import { initCurrentPageview } from '@/utils/pageview'

      document.addEventListener('astro:page-load', () => {
        if (!window.location.pathname.startsWith('/projects/ConTrack')) return

        initCurrentPageview('/projects/ConTrack')

        const videos = [...document.querySelectorAll('video.lazy-video')] as HTMLVideoElement[]
        const loadVideo = (video: HTMLVideoElement) => {
          const src = video.dataset.src
          if (!src || video.src) return
          video.preload = 'auto'
          video.src = src
          video.load()
          video.play().catch(() => {})
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              const video = entry.target as HTMLVideoElement
              if (entry.isIntersecting) {
                loadVideo(video)
                video.play().catch(() => {})
              } else {
                video.pause()
              }
            })
          },
          { rootMargin: '360px 0px', threshold: 0.08 }
        )

        videos.forEach((video) => observer.observe(video))
      })
    </script>
    <Analytics />
    <SpeedInsights />
  </body>
</html>

<style>
  :global(body.contrack-body) {
    --contrack-bg: #fff;
    --contrack-text: #111;
    --contrack-muted: #555;
    --contrack-line: #ddd;
    --contrack-code-bg: #f7f7f7;
    --contrack-video-bg: #000;
    margin: 0;
    background: var(--contrack-bg);
    color: var(--contrack-text);
  }

  :global(html.dark body.contrack-body) {
    --contrack-bg: #0b0b10;
    --contrack-text: #e8e8ee;
    --contrack-muted: #a6a6b3;
    --contrack-line: #31313a;
    --contrack-code-bg: #17171f;
  }

  .page {
    width: min(1200px, calc(100% - 32px));
    margin: 0 auto;
    padding: 48px 0 72px;
    font-size: 16px;
    line-height: 1.62;
  }

  .hero {
    text-align: center;
  }

  h1 {
    max-width: 1100px;
    margin: 0 auto 18px;
    font-size: clamp(2rem, 5vw, 3.4rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .authors,
  .affiliations,
  .links {
    margin: 6px 0;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    margin-top: 18px;
  }

  .authors {
    font-size: 1.08rem;
  }

  .affiliations,
  .muted {
    color: var(--contrack-muted);
  }

  .teaser {
    max-width: 900px;
    margin: 34px auto 46px;
  }

  .teaser video {
    display: block;
    width: 100%;
  }

  section {
    margin-top: 52px;
  }

  h2 {
    margin: 0 0 18px;
    border-bottom: 1px solid var(--contrack-line);
    padding-bottom: 6px;
    font-size: 1.65rem;
    font-weight: 700;
    letter-spacing: 0;
  }

  h3 {
    margin: 30px 0 10px;
    font-size: 1.08rem;
    font-weight: 700;
    letter-spacing: 0;
  }

  h4 {
    margin: 18px 0 10px;
    font-size: 1rem;
    font-weight: 700;
  }

  p {
    margin: 0 0 16px;
  }

  .overview-list {
    margin: 8px 0 0;
    padding-left: 0;
    list-style: none;
  }

  .overview-list li {
    position: relative;
    margin: 8px 0;
    padding-left: 1.1rem;
  }

  .overview-list li::before {
    position: absolute;
    top: 0.72em;
    left: 0;
    width: 0.34rem;
    height: 0.34rem;
    border-radius: 50%;
    background: var(--contrack-text);
    content: '';
  }

  video {
    display: block;
    width: 100%;
    background: var(--contrack-video-bg);
  }

  .main-video {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
    background: var(--contrack-video-bg);
  }

  .method-steps {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    counter-reset: method-step;
    margin: 6px 0 0;
    padding: 0;
    list-style: none;
  }

  .method-steps li {
    counter-increment: method-step;
    border: 1px solid var(--contrack-line);
    border-radius: 8px;
    padding: 14px 16px 16px;
  }

  .method-steps strong {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 7px;
    line-height: 1.25;
  }

  .method-steps strong::before {
    flex: 0 0 auto;
    color: var(--contrack-muted);
    font-size: 0.82rem;
    font-weight: 700;
    content: counter(method-step, decimal-leading-zero);
  }

  .method-steps span {
    display: block;
    color: var(--contrack-muted);
    font-size: 0.96rem;
    line-height: 1.55;
  }

  strong {
    font-weight: 800;
  }

  .sim-group {
    margin-top: 18px;
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  .real-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  figure {
    margin: 0;
  }

  .video-grid video,
  .real-grid video {
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  figcaption {
    margin-top: 5px;
    color: var(--contrack-muted);
    font-size: 0.86rem;
    line-height: 1.3;
  }

  pre {
    overflow-x: auto;
    margin: 0;
    background: var(--contrack-code-bg);
    padding: 14px 16px;
    font-size: 0.9rem;
    line-height: 1.55;
  }

  @media (max-width: 860px) {
    .method-steps {
      grid-template-columns: 1fr;
    }

    .video-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .page {
      width: min(100% - 24px, 1200px);
      padding-top: 32px;
    }
  }
</style>
