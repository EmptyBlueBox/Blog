]

const realVideos = [
  [
    'Cylinder',
    'real-8x-sdr-720p/grab-s1_cylindermedium_offhand_1-xarm7_xhand-268_628_8x_sdr-720p.mp4'
  ],
  ['Hammer', 'real-8x-sdr-720p/grab-s1_hammer_use_1-xarm7_xhand-120_840_8x_sdr-720p.mp4'],
  ['Cube', 'real-8x-sdr-720p/grab-s2_cubemedium_inspect_1-xarm7_xhand-192_672_8x_sdr-720p.mp4']
]

const bibtex = `@misc{liang2026contrack,
      title={ConTrack: Constrained Hand Motion Tracking with Adaptive Trade-off Control}, 
      author={Liang, Yutong and Peng, Quanquan and Qiu, Ri-Zhao and Wang, Xiaolong},
      year={2026},
      eprint={xxxx.xxxxx},
      archivePrefix={arXiv},
      primaryClass={cs.RO},
      url={https://arxiv.org/abs/xxxx.xxxxx}, 
}`

const objectiveEquation = katex.renderToString(
  String.raw`\begin{aligned}
    \max_{\pi}\quad & J_s(\pi) \\
    \mathrm{s.t.}\quad & J_g(\pi) \ge \alpha J_g^\star \\
    J_g^\star &\leftarrow \max\{J_g^\star, J_g\}
  \end{aligned}`,
  { displayMode: true }
)

const mixingEquation = katex.renderToString(
  String.raw`\begin{aligned}
    A_{\mathrm{mix}} &= w_{\mathrm{task}}A_g+(1-w_{\mathrm{task}})A_s+A_p \\
    w_{\mathrm{task}} &= \sigma(\lambda),\qquad
    \lambda \leftarrow \lambda+\eta\left(\alpha-\frac{J_g}{J_g^\star}\right)
  \end{aligned}`,
  { displayMode: true }
)

const resetEquation = katex.renderToString(
  String.raw`\ell_k=t_{\mathrm{end}}-k+1,\qquad
  u_k=\frac{\bar{\ell}_k}{T-k},\qquad
  p(k)\propto \exp\left(-\frac{u_k}{\tau}\right)`,
  { displayMode: true }
)

const methodSteps = [
  {
    title: 'Constrain the object',
    text: 'The task return measures object pose tracking. ConTrack keeps it above an alpha-scaled target instead of tuning a fixed task weight for each clip.',
    equation: objectiveEquation
  },
  {
    title: 'Adapt the trade-off',
    text: 'A scalar dual update changes the PPO task-style mix. Below the target, the policy pushes harder on the object; above it, capacity goes back to hand motion and contacts.',
    equation: mixingEquation
  },
  {
    title: 'Train near the failure boundary',
    text: 'The reset library stores states the policy actually reached. Long clips get practiced around the current failure point, then the reset distribution moves earlier as tracking improves.',
    equation: resetEquation
  },
  {
    title: 'Use contact priors',
    text: 'Reference contact events and object-local point targets tell each robot link when and where to touch, making style fidelity physical rather than only joint-level.'
  }
]
---

<html lang='en-US'>
  <head>
    <BaseHead
      title='ConTrack'
      description={description}
      canonical='/projects/ConTrack'
      ogImage={teaserImage.src}
    />
    <ThemeProvider />
  </head>
  <body class='contrack-body'>
    <main class='page'>
      <header class='hero'>
        <h1>{title}</h1>
        <p class='authors'>
          {
            authors.map((author, index) => (
              <>
                <a
                  href={author.href}
                  target={author.href === '#' ? undefined : '_blank'}
                  rel={author.href === '#' ? undefined : 'noopener noreferrer'}
                >
                  {author.name}
                </a>
                {index < authors.length - 1 && <span>, </span>}
              </>
            ))
          }
        </p>
        <p class='affiliations'>University of California San Diego</p>
        <p class='links'>
          {
            links.map((link) => (
              <a
                href={link.href}
                target={link.href === '#' ? undefined : '_blank'}
                rel={link.href === '#' ? undefined : 'noopener noreferrer'}
              >
                {link.label}
              </a>
            ))
          }
        </p>
      </header>

      <figure class='teaser'>
        <img src={teaserImage.src} alt='ConTrack overview teaser.' />
        <figcaption class='takeaway'>
          Keep the object on track, and let the remaining freedom carry the motion style.
        </figcaption>
      </figure>

      <section>
        <h2>Overview</h2>
        <p>{overviewIntro}</p>
        <ul class='overview-list'>
          {overviewPoints.map((point) => <li>{point}</li>)}
        </ul>
      </section>

      <section>
        <h2>Video</h2>
        <iframe
          class='main-video'
          src='https://www.youtube.com/embed/Rr96tHf0ZUU'
          title='ConTrack video'
          allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share'
          allowfullscreen></iframe>
      </section>

      <section>
        <h2>Method</h2>
        <ul class='method-steps'>
          {
            methodSteps.map((step) => (
              <li>
                <div>
                  <strong>{step.title}</strong>
                  <span>{step.text}</span>
                  {step.equation && <div class='step-equation' set:html={step.equation} />}
                </div>
              </li>
            ))
          }
        </ul>
      </section>

      <section>
        <h2>Experiment</h2>
        <p>
          We evaluate on GRAB, ARCTIC, and DexterHand. All learning-based methods are trained for
          5000 PPO updates per clip under a fixed simulator-step budget. Evaluation always starts
          from the first reference frame, with termination at 0.10 m object translation error or
          1.00 rad object rotation error.
        </p>

        <h3>Main Results</h3>
        <div class='table-wrap'>
          <table>
            <thead>
              <tr>{metricHeaders.map((header) => <th>{header}</th>)}</tr>
            </thead>
            <tbody>
              {
                baselineRows.map((row) => (
                  <tr>
                    {row.map((cell) => (
                      <td>{typeof cell === 'string' ? cell : <strong>{cell.value}</strong>}</td>
                    ))}
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>

        <h3>Ours by Dataset</h3>
        <div class='table-wrap'>
          <table>
            <thead>
              <tr>{metricHeaders.map((header) => <th>{header}</th>)}</tr>
            </thead>
            <tbody>
              {
                datasetRows.map((row) => (
                  <tr>
                    {row.map((cell) => (
                      <td>{cell}</td>
                    ))}
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>

        <h3>Adaptive Mixing Ablation</h3>
        <div class='table-wrap'>
          <table>
            <thead>
              <tr>{metricHeaders.map((header) => <th>{header}</th>)}</tr>
            </thead>
            <tbody>
              {
                ablationRows.map((row) => (
                  <tr>
                    {row.map((cell) => (
                      <td>{typeof cell === 'string' ? cell : <strong>{cell.value}</strong>}</td>
                    ))}
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>

        <h3>Simulation Videos</h3>
        {
          simGroups.map((group) => (
            <div class='sim-group'>
              <h4>{group.name}</h4>
              <div class='video-grid'>
                {group.videos.map(([name, src]) => (
                  <figure>
                    <video
                      class='lazy-video'
                      muted
                      loop
                      playsinline
                      autoplay
                      preload='none'
                      data-src={`${cdn}${src}`}
                    />
                    <figcaption>{name}</figcaption>
                  </figure>
                ))}
              </div>
            </div>
          ))
        }

        <h3>Real Robot Videos</h3>
        <div class='real-grid'>
          {
            realVideos.map(([name, src]) => (
              <figure>
                <video
                  class='lazy-video'
                  muted
                  loop
                  playsinline
                  autoplay
                  preload='none'
                  data-src={`${cdn}${src}`}
                />
                <figcaption>{name}</figcaption>
              </figure>
            ))
          }
        </div>
      </section>

      <section>
        <h2>BibTeX</h2>
        <pre><code>{bibtex}</code></pre>
      </section>
    </main>
    <script>
      const videos = [...document.querySelectorAll('video.lazy-video')] as HTMLVideoElement[]
      const loadVideo = (video: HTMLVideoElement) => {
        const src = video.dataset.src
        if (!src || video.src) return
        video.preload = 'auto'
        video.src = src
        video.load()
        video.play().catch(() => {})
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const video = entry.target as HTMLVideoElement
            if (entry.isIntersecting) {
              loadVideo(video)
              video.play().catch(() => {})
            } else {
              video.pause()
            }
          })
        },
        { rootMargin: '360px 0px', threshold: 0.08 }
      )

      videos.forEach((video) => observer.observe(video))
    </script>
    <Analytics />
    <SpeedInsights />
  </body>
</html>

<style>
  :global(body.contrack-body) {
    --contrack-bg: #fff;
    --contrack-text: #111;
    --contrack-muted: #555;
    --contrack-link: #1f5fae;
    --contrack-button-border: #d8d8d8;
    --contrack-button-hover: #f7f7f4;
    --contrack-button-ink: #171717;
    --contrack-line: #ddd;
    --contrack-code-bg: #f7f7f7;
    --contrack-video-bg: #000;
    margin: 0;
    background: var(--contrack-bg);
    color: var(--contrack-text);
  }

  :global(html.dark body.contrack-body) {
    --contrack-bg: #0b0b10;
    --contrack-text: #e8e8ee;
    --contrack-muted: #a6a6b3;
    --contrack-link: #8ab4ff;
    --contrack-button-border: #3a3a45;
    --contrack-button-hover: #15151c;
    --contrack-button-ink: #ededf3;
    --contrack-line: #31313a;
    --contrack-code-bg: #17171f;
  }

  .page {
    width: min(980px, calc(100% - 32px));
    margin: 0 auto;
    padding: 48px 0 72px;
    font-size: 16px;
    line-height: 1.62;
  }

  .hero {
    text-align: center;
  }

  h1 {
    max-width: 900px;
    margin: 0 auto 18px;
    font-size: clamp(2rem, 5vw, 3.4rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .authors,
  .affiliations,
  .links {
    margin: 6px 0;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    margin-top: 18px;
  }

  .authors {
    font-size: 1.08rem;
  }

  .affiliations,
  .muted {
    color: var(--contrack-muted);
  }

  a {
    color: var(--contrack-link);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  .links a {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    border: 1px solid var(--contrack-button-border);
    border-radius: 2px;
    background: transparent;
    padding: 0 13px;
    color: var(--contrack-button-ink);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono',
      'Courier New', monospace;
    font-size: 0.78rem;
    font-weight: 500;
    line-height: 1.2;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      transform 160ms ease;
  }

  .links a:hover {
    background: var(--contrack-button-hover);
    border-color: var(--contrack-text);
    text-decoration: none;
    transform: translateY(-1px);
  }

  .teaser {
    margin: 34px 0 46px;
  }

  .teaser img {
    display: block;
    width: 100%;
  }

  .takeaway {
    margin-top: 12px;
    color: var(--contrack-text);
    font-size: 1.12rem;
    font-weight: 600;
    text-align: center;
  }

  section {
    margin-top: 52px;
  }

  h2 {
    margin: 0 0 18px;
    border-bottom: 1px solid var(--contrack-line);
    padding-bottom: 6px;
    font-size: 1.65rem;
    font-weight: 700;
    letter-spacing: 0;
  }

  h3 {
    margin: 30px 0 10px;
    font-size: 1.08rem;
    font-weight: 700;
    letter-spacing: 0;
  }

  h4 {
    margin: 18px 0 10px;
    font-size: 1rem;
    font-weight: 700;
  }

  p {
    margin: 0 0 16px;
  }

  .overview-list {
    margin: 8px 0 0;
    padding-left: 0;
    list-style: none;
  }

  .overview-list li {
    position: relative;
    margin: 8px 0;
    padding-left: 1.1rem;
  }

  .overview-list li::before {
    position: absolute;
    top: 0.72em;
    left: 0;
    width: 0.34rem;
    height: 0.34rem;
    border-radius: 50%;
    background: var(--contrack-text);
    content: '';
  }

  video {
    display: block;
    width: 100%;
    background: var(--contrack-video-bg);
  }

  .main-video {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
    background: var(--contrack-video-bg);
  }

  .step-equation {
    max-width: 100%;
    margin-top: 10px;
    overflow-x: auto;
    border-left: 2px solid var(--contrack-line);
    padding: 4px 0 4px 14px;
  }

  .step-equation :global(.katex-display) {
    margin: 0;
    color: var(--contrack-text);
    text-align: left;
  }

  .step-equation :global(.katex) {
    font-size: 0.94rem;
  }

  .method-steps {
    display: grid;
    gap: 14px;
    margin: 6px 0 0;
    padding: 0;
    list-style: none;
  }

  .method-steps li {
    border-top: 1px solid var(--contrack-line);
    padding-top: 14px;
  }

  .method-steps li:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .method-steps strong {
    display: block;
