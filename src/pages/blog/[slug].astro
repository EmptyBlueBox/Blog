---
import PostLayout from '@/layouts/BlogPost.astro'
import { render, type CollectionEntry } from 'astro:content'

import {
  getAllCollections,
  getBaseSlugFromId,
  getEntryLanguageTag,
  getLanguageLabel,
  normalizeLanguage,
  getTranslationInfo
} from '@/utils/collections'

export const prerender = true

export async function getStaticPaths() {
  const posts = await getAllCollections()
  const exactSlugs = new Set(posts.map((post) => post.id))
  const entriesByBaseSlug = new Map<string, CollectionEntry<'post'>[]>()

  for (const post of posts) {
    const baseSlug = getBaseSlugFromId(post.id)
    const entries = entriesByBaseSlug.get(baseSlug)
    if (entries) entries.push(post)
    else entriesByBaseSlug.set(baseSlug, [post])
  }

  return [
    ...posts.map((post: CollectionEntry<'post'>) => ({
      params: { slug: post.id },
      props: post
    })),
    ...Array.from(entriesByBaseSlug.entries())
      .filter(([baseSlug]) => !exactSlugs.has(baseSlug))
      .map(([baseSlug, entries]) => ({
        params: { slug: baseSlug },
        props:
          entries.find((entry) => normalizeLanguage(entry.data.language) === 'en') ??
          entries.find((entry) => normalizeLanguage(entry.data.language) === 'zh') ??
          entries[0]
      }))
  ]
}
type Props = CollectionEntry<'post'>

const post = Astro.props
const { Content, headings } = await render(post)
const allPosts = await getAllCollections()
const translationInfo = getTranslationInfo(post, allPosts)
const translations = translationInfo
  ? translationInfo.entries.map(({ entry, normalizedLanguage }) => ({
      href: `/blog/${entry.id}`,
      label: getLanguageLabel(normalizedLanguage),
      isActive: entry.id === post.id
    }))
  : []

const commentPath = translationInfo && translationInfo.entries.length > 1
  ? `/blog/${getBaseSlugFromId(post.id)}`
  : `/blog/${post.id}`

const alternates = translationInfo
  ? [
      ...translationInfo.entries.map(({ entry }) => ({
        href: new URL(`/blog/${entry.id}`, Astro.site).href,
        hreflang: getEntryLanguageTag(entry)
      })),
      {
        href: new URL(`/blog/${translationInfo.entries[0].entry.id}`, Astro.site).href,
        hreflang: 'x-default'
      }
    ]
  : undefined
---

<PostLayout
  post={post}
  {headings}
  translations={translations}
  commentPath={commentPath}
  alternates={alternates}
>
  <Content />
</PostLayout>
