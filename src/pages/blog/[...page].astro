---
import type { GetStaticPaths } from 'astro'
import PageLayout from '@/layouts/BaseLayout.astro'

import PostPreview from '@/components/blog/PostPreview.astro'
import { Button } from '@/components/user'
import {
  get_entry_languages,
  getAllCollections,
  getCanonicalCollections,
  getUniqueTagsWithCount,
  normalizeLanguage,
  sortMDByDate
} from '@/utils/collections'
import { siteConfig } from '@/site-config'

export const getStaticPaths = (async ({ paginate }) => {
  const all_posts = await getAllCollections()
  const filters = [
    { id: 'all', posts: await getCanonicalCollections() },
    {
      id: 'en',
      posts: all_posts.filter((post) => normalizeLanguage(post.data.language) === 'en')
    },
    {
      id: 'zh',
      posts: all_posts.filter((post) => normalizeLanguage(post.data.language) === 'zh')
    }
  ] as const

  return filters.flatMap(({ id, posts }) =>
    paginate(sortMDByDate(posts), {
      pageSize: siteConfig.blog.pageSize,
      props: {
        filter: id,
        uniqueTags: getUniqueTagsWithCount(posts)
          .slice(0, 8)
          .map(([tag]) => tag)
      }
    }).map(({ params, props }) => ({
      params: {
        page: id === 'all' ? params.page : params.page ? `${id}/${params.page}` : id
      },
      props
    }))
  )
}) satisfies GetStaticPaths

const { page, uniqueTags, filter } = Astro.props
const all_posts = await getAllCollections()

const meta = {
  description: 'Posts and archives from Yutong Liang.',
  title: filter === 'all' ? 'Blog' : filter === 'en' ? 'English Writing' : '中文文章'
}

const paginationProps = {
  ...(page.currentPage > 1 && {
    prevUrl: {
      text: `Previous Page`,
      url:
        filter === 'all'
          ? page.currentPage === 2
            ? '/blog'
            : `/blog/${page.currentPage - 1}`
          : page.currentPage === 2
            ? `/blog/${filter}`
            : `/blog/${filter}/${page.currentPage - 1}`
    }
  }),
  ...(page.currentPage < page.lastPage && {
    nextUrl: {
      text: `Next Page`,
      url:
        filter === 'all'
          ? `/blog/${page.currentPage + 1}`
          : `/blog/${filter}/${page.currentPage + 1}`
    }
  })
}

const filters = [
  { id: 'all', label: 'All', href: '/blog' },
  { id: 'en', label: 'English', href: '/blog/en' },
  { id: 'zh', label: 'Chinese', href: '/blog/zh' }
] as const
---

<PageLayout {meta}>
  <div class='w-full'>
    <h1 class='mt-6 mb-4 text-3xl font-medium sm:mt-10'>Blog</h1>
    <nav class='mb-6 flex flex-wrap gap-2' aria-label='Blog language'>
      {
        filters.map((item) => (
          <Button
            title={item.label}
            href={item.href}
            style='pill'
            class={filter === item.id ? 'border-primary/50 bg-muted text-foreground' : undefined}
            aria-current={filter === item.id ? 'page' : undefined}
          />
        ))
      }
    </nav>

    {
      page.data.length === 0 ? (
        <p>No posts yet.</p>
      ) : (
        <>
          <div class='grid gap-y-16 sm:grid-cols-[3fr_1fr] sm:gap-x-8'>
            <section aria-label='Blog posts list'>
              <div class='mb-3 flex flex-col justify-between text-sm sm:mb-5 sm:flex-row'>
                <span class='text-muted-foreground'>
                  Page {page.currentPage} - Showing {page.data.length} of {page.total}
                  {page.total === 1 ? ' post' : ' posts'}
                </span>
                <Button title='View All Posts' class='ms-auto' href='/archives' style='ahead' />
              </div>
              <ul class='flex flex-col gap-y-4 text-start'>
                {page.data.map((p) => (
                  <PostPreview
                    as='h2'
                    post={p}
                    detailed
                    languages={filter === 'all' ? get_entry_languages(p, all_posts) : [filter]}
                  />
                ))}
              </ul>
              {(paginationProps.prevUrl || paginationProps.nextUrl) && (
                <nav class='mt-4 flex items-center gap-x-4 sm:mt-6'>
                  {paginationProps.prevUrl && (
                    <Button
                      title={paginationProps.prevUrl.text}
                      href={paginationProps.prevUrl.url}
                      style='previous'
                      class='me-auto'
                    />
                  )}
                  {paginationProps.nextUrl && (
                    <Button
                      title={paginationProps.nextUrl.text}
                      href={paginationProps.nextUrl.url}
                      style='ahead'
                      class='ms-auto'
                    />
                  )}
                </nav>
              )}
            </section>
            {!!uniqueTags.length && (
              <aside id='sidebar'>
                <h2 class='mb-4 flex items-center text-lg font-semibold'>
                  <svg class='me-2 size-6'>
                    <use href='/icons/ui.svg#mingcute-tag-2-line' />
                  </svg>
                  Tags
                </h2>
                <ul class='text-muted-foreground flex flex-wrap gap-2'>
                  {uniqueTags.map((tag) => (
                    <li>
                      <Button title={tag} href={`/tags/${encodeURIComponent(tag)}`} style='pill' />
                    </li>
                  ))}
                </ul>
                <div class='mt-4 block sm:text-end'>
                  <Button title='All Topics' href='/tags' style='ahead' />
                </div>
              </aside>
            )}
          </div>
        </>
      )
    }
  </div>
</PageLayout>
