---
import { publicationsData } from '@/data/publications'
import PageLayout from '@/layouts/BaseLayout.astro'
import { Image } from 'astro:assets'

import SocialLinksRow from '@/components/about/SocialLinksRow.astro'
import Section from '@/components/home/Section.astro'
import PublicationEntry from '@/components/projects/PublicationEntry.astro'
import { Button, Card, FormattedDate, Label } from '@/components/user'
import {
  getAllCollections,
  getTranslationInfo,
  normalizeLanguage,
  selectCanonicalEntries,
  sortMDByDate
} from '@/utils/collections'
import avatarMain from '@/assets/avatar/avatar_main.jpeg'
import pkuImage from '@/assets/homepage/source/pku_360.png'
import ucsdImage from '@/assets/homepage/source/ucsd_1024.png'
// import nkImage from '@/assets/homepage/source/nk_1182x1134.png'
import { siteConfig } from '@/site-config'

export const prerender = true

const MAX_POSTS = 10

const socialLinks = [
  {
    href: 'mailto:lyt0112@outlook.com',
    label: 'Email',
    icon: 'mail'
  },
  {
    href: 'https://github.com/EmptyBlueBox',
    label: 'GitHub',
    icon: 'github'
  },
  {
    href: 'https://scholar.google.com/citations?user=YtGyys8AAAAJ&hl=en',
    label: 'Google Scholar',
    icon: 'google-scholar'
  },
  {
    href: 'https://x.com/YutongLiang_',
    label: 'X',
    icon: 'x'
  },
  {
    href: 'https://cdn.lyt0112.com/CV-Yutong_Liang.pdf',
    label: 'CV',
    icon: 'cv'
  }
]

const languageLabels = {
  en: 'EN',
  zh: 'ZH',
  unknown: ''
}

const allPosts = await getAllCollections()
const recentPosts = sortMDByDate(selectCanonicalEntries(allPosts))
  .slice(0, MAX_POSTS)
  .map((post) => ({
    post,
    language: (
      getTranslationInfo(post, allPosts)?.entries ?? [
        { normalizedLanguage: normalizeLanguage(post.data.language) }
      ]
    )
      .map(({ normalizedLanguage }) => languageLabels[normalizedLanguage])
      .filter(Boolean)
  }))
---

<PageLayout meta={{ title: 'Home' }} highlightColor='#659EB966'>
  <div class='mx-auto flex w-full flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
    <section class='flex flex-col items-center gap-y-8'>
      <div
        class='mx-auto grid w-fit max-w-full grid-cols-1 items-center justify-items-center gap-6 text-center sm:grid-cols-[10rem_minmax(0,36rem)] sm:justify-items-start sm:text-left'
      >
        <div class='flex-shrink-0 overflow-hidden rounded-full border border-border/60'>
          <Image
            src={avatarMain}
            densities={[1, 2, 4.5]}
            width={160}
            height={160}
            alt='Profile photo of Yutong Liang'
            class='h-40 w-40 object-cover'
            priority
          />
        </div>

        <div class='flex min-w-0 flex-col items-center gap-y-4 sm:items-start'>
          <h1 class='text-4xl font-medium tracking-tight'>{siteConfig.author}</h1>
          <p class='max-w-xl text-balance text-base leading-7 text-muted-foreground'>
            I study dexterous robotic manipulation through human demonstrations, reinforcement
            learning, and world models.
          </p>
          <div class='flex flex-wrap justify-center gap-x-5 gap-y-3 sm:justify-start'>
            <Label title='San Diego · US' class='text-muted-foreground'>
              <svg class='size-5' slot='icon'>
                <use href='/icons/social.svg#mingcute-location-line'></use>
              </svg>
            </Label>
            <Label title='Robotics · Character Animation' class='text-muted-foreground'>
              <svg class='size-5' slot='icon'>
                <use href='/icons/social.svg#academic-cap'></use>
              </svg>
            </Label>
          </div>
        </div>
      </div>
    </section>

    <Section title='About' title_position='top'>
      <p>
        Hi there! I'm Yutong Liang, a first-year graduate student in Computer Science and
        Engineering at the University of California San Diego, advised by Prof. Xiaolong Wang.
      </p>
      <p>
        My research aims to develop general-purpose physics agents that can comprehend the world and operate with human-level dexterity.
      </p>
      <p>
        I believe the next leap in robot manipulation will come from world-action models that learn how the physical world evolves, human demonstrations that inject scalable motion priors, and reinforcement learning that closes the final gap to dynamic, contact-rich control.
      </p>
      <SocialLinksRow links={socialLinks} />
      <Button title='More About Me' class='mt-1' href='/about' style='ahead' />
    </Section>

    <Section title='Publications' title_position='top'>
      <div class='flex flex-col'>
        {
          publicationsData.map((pub) => (
            <PublicationEntry
              variant='paper'
              name={pub.name}
              authors={pub.authors}
              venue={pub.venue}
              year={pub.year}
              note={pub.note}
              image={pub.image}
              video={pub.video}
              links={pub.links}
              takeaway={pub.takeaway}
              bibtex={pub.bibtex}
            />
          ))
        }
      </div>
    </Section>

    <Section title='Education' title_position='top'>
      <Card
        as='a'
        heading='University of California San Diego'
        location='San Diego, United States'
        date='Sep. 2025 - Mar. 2027 (Expected)'
        href='https://cse.ucsd.edu'
        image={ucsdImage}
      >
        <ul class='ms-4 list-disc text-muted-foreground'>
          <li>Jacobs School of Engineering</li>
          <li>M.S. in Computer Science and Engineering</li>
        </ul>
      </Card>
      <Card
        as='a'
        heading='Peking University'
        location='Beijing, China'
        date='Sep. 2021 - Jul. 2025'
        href='https://english.pku.edu.cn/'
        image={pkuImage}
      >
        <ul class='ms-4 list-disc text-muted-foreground'>
          <li>School of EECS</li>
          <li>B.S. in Computer Science and Technology</li>
        </ul>
      </Card>
      <!-- <Card
        as='a'
        heading='Nankai High School'
        location='Tianjin, China'
        date='Sep. 2018 - Jul. 2021'
        href='https://nkzx.tj.edu.cn/'
        image={nkImage}
      >
        <ul class='ms-4 list-disc text-muted-foreground'>
          <li>High School Diploma</li>
        </ul>
      </Card> -->
    </Section>

    {
      recentPosts.length > 0 && (
        <Section title='Recent Writing' title_position='top'>
          <ul>
            {recentPosts.map(({ post, language }) => (
              <li class='border-b border-border/60 last:border-b-0'>
                <a
                  href={`/blog/${post.id}`}
                  class='group grid gap-x-5 gap-y-2 py-4 transition-colors hover:text-primary sm:grid-cols-[8.25rem_minmax(0,1fr)_2.5rem]'
                >
                  <div class='flex items-center gap-3 text-xs text-muted-foreground sm:flex-col sm:items-start sm:justify-center sm:gap-1'>
                    <FormattedDate date={post.data.updatedDate ?? post.data.publishDate} />
                    {!!language.length && (
                      <span class='flex items-center gap-1.5 font-mono text-muted-foreground'>
                        {language.map((item, languageIndex) => (
                          <>
                            {languageIndex > 0 && (
                              <span class='text-muted-foreground/50' aria-hidden='true'>
                                ·
                              </span>
                            )}
                            <span>{item}</span>
                          </>
                        ))}
                      </span>
                    )}
                  </div>
                  <div class='min-w-0'>
                    <h3 class='text-base font-medium leading-7'>
                      {post.data.draft && <span class='text-red-500'>(Draft) </span>}
                      {post.data.title}
                    </h3>
                    <p class='line-clamp-1 text-sm leading-6 text-muted-foreground'>
                      {post.data.description}
                    </p>
                  </div>
                  <span class='hidden items-center justify-end text-muted-foreground transition-colors duration-300 group-hover:text-primary sm:flex'>
                    <svg
                      xmlns='http://www.w3.org/2000/svg'
                      width='16'
                      height='16'
                      viewBox='0 0 24 24'
                      fill='none'
                      stroke-width='2.5'
                      stroke-linecap='round'
                      stroke-linejoin='round'
                      class='stroke-current'
                    >
                      <line
                        x1='5'
                        y1='12'
                        x2='19'
                        y2='12'
                        class='translate-x-4 scale-x-0 transition-all duration-300 ease-in-out group-hover:translate-x-1 group-hover:scale-x-100'
                      />
                      <polyline
                        points='12 5 19 12 12 19'
                        class='translate-x-0 transition-all duration-300 ease-in-out group-hover:translate-x-1'
                      />
                    </svg>
                  </span>
                </a>
              </li>
            ))}
          </ul>
          <Button title='More Posts' class='mt-1' href='/blog' style='ahead' />
        </Section>
      )
    }
  </div>
</PageLayout>
