---
import { publicationsData } from '@/data/publications'
import { socialLinks } from '@/data/social_links'
import PageLayout from '@/layouts/BaseLayout.astro'
import { Image } from 'astro:assets'

import SocialLinksRow from '@/components/about/SocialLinksRow.astro'
import Section from '@/components/home/Section.astro'
import PublicationEntry from '@/components/projects/PublicationEntry.astro'
import { Button, Card, FormattedDate, Label } from '@/components/user'
import { getAllCollections, getTranslationInfo, normalizeLanguage } from '@/utils/collections'
import avatarMain from '@/assets/about/profile_01.jpeg'
import pkuImage from '@/assets/homepage/source/pku_360.png'
import ucsdImage from '@/assets/homepage/source/ucsd_360.png'
import { siteConfig } from '@/site-config'

const selectedPublicationNames = [
  'ConTrack: Constrained Hand Motion Tracking with Adaptive Trade-off Control',
  'XL-VLA: Cross-Hand Latent Representation for Vision-Language-Action Models',
  'DexterCap: An Affordable and Automated System for Capturing Dexterous Hand-Object Manipulation'
]
const selectedPublications = selectedPublicationNames.map((name) =>
  publicationsData.find((publication) => publication.name === name)!
)
const selectedPostIds = ['human_demo-en', 'blindfold-en', 'retargeting-en']

const languageLabels = {
  en: 'EN',
  zh: 'ZH',
  unknown: ''
}

const allPosts = await getAllCollections()
const selectedPosts = selectedPostIds.map((id) => {
  const post = allPosts.find((entry) => entry.id === id)!
  return {
    post,
    language: (
      getTranslationInfo(post, allPosts)?.entries ?? [
        { normalizedLanguage: normalizeLanguage(post.data.language) }
      ]
    )
      .map(({ normalizedLanguage }) => languageLabels[normalizedLanguage])
      .filter(Boolean)
  }
})
---

<PageLayout meta={{ title: 'Robotics Researcher' }} highlightColor='#659EB966'>
  <div class='mx-auto flex w-full flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
    <section class='flex flex-col items-center gap-y-8'>
      <div
        class='mx-auto grid w-fit max-w-full grid-cols-1 items-center justify-items-center gap-6 text-center sm:grid-cols-[10rem_minmax(0,36rem)] sm:justify-items-start sm:text-left'
      >
        <div class='border-border/60 flex-shrink-0 overflow-hidden rounded-full border'>
          <Image
            src={avatarMain}
            densities={[1, 2, 4.5]}
            width={160}
            height={160}
            alt='Profile photo of Yutong Liang'
            class='h-40 w-40 object-cover'
            priority
          />
        </div>

        <div class='flex min-w-0 flex-col items-center gap-y-4 sm:items-start'>
          <h1 class='text-4xl font-medium tracking-tight'>{siteConfig.author}</h1>
          <div class='flex flex-wrap justify-center gap-x-5 gap-y-3 sm:justify-start'>
            <Label title='San Diego, CA' class='text-muted-foreground'>
              <svg class='size-5' slot='icon'>
                <use href='/icons/social.svg#mingcute-location-line'></use>
              </svg>
            </Label>
            <Label title='Robot Learning · Character Animation' class='text-muted-foreground'>
              <svg class='size-5' slot='icon'>
                <use href='/icons/social.svg#academic-cap'></use>
              </svg>
            </Label>
          </div>
        </div>
      </div>
    </section>

    <Section title='Research' title_position='top'>
      <p>
        Hi there! I'm Yutong Liang, a graduate student in Computer Science and Engineering at the
        University of California San Diego, advised by Prof. Xiaolong Wang.
      </p>
      <p>
        I build dexterous robot learning systems that transfer human motion across simulation and
        reality. My current work combines human demonstrations, world models, and reinforcement
        learning for dynamic, contact-rich manipulation.
      </p>
      <SocialLinksRow links={socialLinks} />
      <Button title='About Me' class='mt-1' href='/about' style='ahead' />
    </Section>

    <Section title='Selected Publications' title_position='top'>
      <div class='flex flex-col'>
        {
          selectedPublications.map((pub) => (
            <PublicationEntry
              variant='paper'
              name={pub.name}
              authors={pub.authors}
              venue={pub.venue}
              year={pub.year}
              note={pub.note}
              image={pub.image}
              video={pub.video}
              links={pub.links}
              takeaway={pub.takeaway}
              bibtex={pub.bibtex}
              compact_on_mobile
            />
          ))
        }
      </div>
      <Button title='All Publications' class='mt-1' href='/projects' style='ahead' />
    </Section>

    {
      selectedPosts.length > 0 && (
        <Section title='Selected Writing' title_position='top'>
          <ul>
            {selectedPosts.map(({ post, language }) => (
              <li class='border-border/60 border-b last:border-b-0'>
                <a
                  href={`/blog/${post.id}`}
                  class='group hover:text-primary grid gap-x-5 gap-y-2 py-4 transition-colors sm:grid-cols-[8.25rem_minmax(0,1fr)_2.5rem]'
                >
                  <div class='text-muted-foreground flex items-center gap-3 text-xs sm:flex-col sm:items-start sm:justify-center sm:gap-1'>
                    <FormattedDate date={post.data.updatedDate ?? post.data.publishDate} />
                    {!!language.length && (
                      <span class='text-muted-foreground flex items-center gap-1.5 font-mono'>
                        {language.map((item, languageIndex) => (
                          <>
                            {languageIndex > 0 && (
                              <span class='text-muted-foreground/50' aria-hidden='true'>
                                ·
                              </span>
                            )}
                            <span>{item}</span>
                          </>
                        ))}
                      </span>
                    )}
                  </div>
                  <div class='min-w-0'>
                    <h3 class='text-base leading-7 font-medium'>{post.data.title}</h3>
                    <p class='text-muted-foreground line-clamp-1 text-sm leading-6'>
                      {post.data.description}
                    </p>
                  </div>
                  <span class='text-muted-foreground group-hover:text-primary hidden items-center justify-end transition-colors duration-300 sm:flex'>
                    <svg
                      xmlns='http://www.w3.org/2000/svg'
                      width='16'
                      height='16'
                      viewBox='0 0 24 24'
                      fill='none'
                      stroke-width='2.5'
                      stroke-linecap='round'
                      stroke-linejoin='round'
                      class='stroke-current'
                    >
                      <line
                        x1='5'
                        y1='12'
                        x2='19'
                        y2='12'
                        class='translate-x-4 scale-x-0 transition-all duration-300 ease-in-out group-hover:translate-x-1 group-hover:scale-x-100'
                      />
                      <polyline
                        points='12 5 19 12 12 19'
                        class='translate-x-0 transition-all duration-300 ease-in-out group-hover:translate-x-1'
                      />
                    </svg>
                  </span>
                </a>
              </li>
            ))}
          </ul>
          <Button title='All Writing' class='mt-1' href='/blog' style='ahead' />
        </Section>
      )
    }

    <Section title='Education' title_position='top'>
      <Card
        as='a'
        heading='University of California San Diego'
        subheading='M.S. in Computer Science and Engineering'
        location='San Diego, United States'
        date='Sep. 2025 - Mar. 2027 (Expected)'
        href='https://cse.ucsd.edu'
        image={ucsdImage}
      />
      <Card
        as='a'
        heading='Peking University'
        subheading='B.S. in Computer Science and Technology'
        location='Beijing, China'
        date='Sep. 2021 - Jul. 2025'
        href='https://english.pku.edu.cn/'
        image={pkuImage}
      />
    </Section>
  </div>
</PageLayout>
