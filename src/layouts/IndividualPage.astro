---
import type { MarkdownHeading, MarkdownLayoutProps } from 'astro'
import PageLayout from '@/layouts/BaseLayout.astro'

import MobileTOC from '@/components/pages/MobileTOC.astro'
import TOC from '@/components/pages/TOC.astro'
import { cn } from '@/utils'
import socialCard from '@/assets/og/social_card.jpg'
import { integrationConfig } from '@/site-config'

type Props = MarkdownLayoutProps<{
  title: string
  description: string
  heroImage?: { src: string }
  language?: string
}> & {
  headings: MarkdownHeading[]
}

const { frontmatter, headings } = Astro.props
const { title, description, heroImage } = frontmatter
const socialImage = heroImage?.src ?? socialCard.src
---

<PageLayout meta={{ title, description, ogImage: socialImage }}>
  <div class='w-full'>
    <div class='mt-6 w-full items-start gap-x-10 md:flex'>
      {
        !!headings.length && (
          <TOC
            class='top-24 z-10 min-w-40 basis-60 max-md:hidden md:sticky md:order-2 lg:shrink-0'
            {headings}
          />
        )
      }
      <article class='min-w-0 grow'>
        <div id='content-header'>
          <div class='article-info max-lg:mx-auto'>
            <h1 class='mt-4 text-2xl font-medium sm:mt-6 sm:mb-2 sm:text-3xl'>
              {title}
            </h1>

            <div
              class='text-muted-foreground mt-4 flex flex-wrap gap-x-4 gap-y-2 text-xs leading-6'
            >
              {
                /* Description */
                description && (
                  <blockquote class='text-muted-foreground text-sm italic'>
                    <q>{description}</q>
                  </blockquote>
                )
              }
            </div>
          </div>
        </div>
        <div
          id='content'
          class={cn('mt-8 max-w-none md:min-w-[45ch]', integrationConfig.typography.class)}
        >
          <slot />
        </div>
      </article>
    </div>

    {!!headings.length && <MobileTOC headings={headings} />}
  </div>
</PageLayout>
