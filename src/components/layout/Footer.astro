---
import { footerConfig, siteConfig } from '@/site-config'

const year = new Date().getFullYear()

const SocialMediaIconId: Record<string, string> = {
  coolapk: 'coolapk-line',
  telegram: 'mingcute-telegram-line',
  github: 'mingcute-github-line',
  bilibili: 'ri-bilibili-line',
  twitter: 'mingcute-twitter-line',
  zhihu: 'ri-zhihu-line',
  steam: 'ri-steam-line',
  netease_music: 'ri-netease-cloud-music-line',
  mail: 'mingcute-mail-line'
}
---

<footer class='mx-auto mt-24 w-full'>
  <div class='border-border border-t pt-5'>
    <div
      class='flex flex-col items-start gap-y-3 sm:flex sm:flex-row sm:items-start sm:justify-between sm:gap-y-0'
    >
      <div class='flex flex-col items-start gap-2 text-sm sm:flex-row sm:gap-x-4'>
        <div class='text-muted-foreground [&_a:hover]:text-primary [&_a]:text-foreground text-sm'>
          © 2024 - {year}
          {' '}
          {siteConfig.author}
        </div>
        <a href='/terms' class='text-muted-foreground'>Site Policy</a>
        <a href='/links' class='text-muted-foreground'>Links</a>
        <div class='text-muted-foreground'>
          <span class='pageview-counter'>
            Site Views <span id='total-pageview-count' class='transition-colors' aria-live='polite'
              >-</span
            >
          </span>
        </div>
        {
          footerConfig.registration && (
            <div class='text-muted-foreground text-sm'>
              <a
                class='hover:text-primary'
                href={footerConfig.registration.url}
                target='_blank'
                rel='noopener noreferrer'
              >
                {footerConfig.registration.text}
              </a>
            </div>
          )
        }
        {
          footerConfig.mengICP && (
            <div class='text-muted-foreground text-sm'>
              <a
                class='hover:text-primary'
                href={footerConfig.mengICP.url}
                target='_blank'
                rel='noopener noreferrer'
              >
                {footerConfig.mengICP.text}
              </a>
            </div>
          )
        }
      </div>
      <div class='flex items-center justify-between'>
        {/* Social Brands */}
        <div class='flex items-center gap-x-4'>
          {
            footerConfig.socialLinks.map((platform: { name: string; url: string }) => (
              <a
                class='text-muted-foreground hover:text-primary inline-block transition-all'
                href={platform.url}
                aria-label={platform.name}
              >
                <svg class='size-6'>
                  <use href={`/icons/social.svg#${SocialMediaIconId[platform.name]}`} />
                </svg>
              </a>
            ))
          }
          {/* Rss */}
          <a
            class='text-muted-foreground hover:text-primary inline-block transition-all'
            href='/rss.xml'
            aria-label='rss'
          >
            <svg class='size-6'>
              <use href='/icons/social.svg#mingcute-rss-2-line'></use>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>

<script>
  /**
   * Lazy-load footer pageview summary after the page is idle.
   *
   * Parameters
   * ----------
   * None
   *
   * Returns
   * -------
   * void, shape=(), dtype=undefined
   *     Imports the pageview client module and initializes the footer counters.
   */
  const init_footer_pageview = () => {
    import('@/utils/pageview.js')
      .then((module) => {
        if (typeof module.initPageviewCounter === 'function') {
          module.initPageviewCounter()
        }
      })
      .catch((err) => console.warn('Pageview script load failed:', err))
  }

  document.addEventListener('astro:page-load', () => {
    if (typeof window.requestIdleCallback === 'function') {
      window.requestIdleCallback(init_footer_pageview, { timeout: 3000 })
    } else {
      setTimeout(init_footer_pageview, 300)
    }
  })
</script>

<style>
  #total-pageview-count[data-partial='true'] {
    color: hsl(var(--destructive));
  }
</style>
