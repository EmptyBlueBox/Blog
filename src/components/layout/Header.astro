---
import { menuLinks, siteConfig } from '@/site-config'

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/'
const isActive = (link: string) => {
  const target = link.replace(/\/$/, '') || '/'
  if (target === '/') return pathname === '/'
  if (target === '/blog') {
    return (
      pathname === '/blog' ||
      pathname.startsWith('/blog/') ||
      pathname === '/archives' ||
      pathname.startsWith('/archives/') ||
      pathname === '/tags' ||
      pathname.startsWith('/tags/')
    )
  }
  return pathname === target || pathname.startsWith(target + '/')
}
---

<header-component
  class='group [&.not-top]:border-border/60 [&.not-top]:bg-muted/25 dark:[&.not-top]:bg-muted/20 sticky top-4 z-30 mb-16 box-content w-full rounded-2xl border border-transparent py-1 transition-all duration-300 [&.not-top]:backdrop-blur-2xl [&.not-top]:backdrop-saturate-150'
>
  <header class='flex flex-wrap text-sm sm:flex-nowrap sm:justify-start'>
    <nav
      class='relative mx-auto flex w-full items-center justify-between sm:flex sm:items-center'
      aria-label='Primary navigation'
    >
      <div
        class='dark:max-sm:group-[.expanded]:bg-muted absolute -top-8 -left-4 -z-10 box-content hidden h-20 w-[calc(100%+2rem)] !duration-0 max-sm:group-[.expanded]:block max-sm:group-[.expanded]:bg-white max-sm:group-[.expanded.not-top]:hidden'
      >
      </div>
      <a
        class='flex-none text-xl font-semibold transition-all duration-300 group-[.not-top]:ms-3 sm:group-[.not-top]:ms-5'
        href='/'>{siteConfig.title}</a
      >

      <!-- menu -->
      <div class='flex gap-x-4 sm:gap-x-6'>
        <div
          id='headerExpandContent'
          class='dark:group-[.expanded.not-top]:bg-muted max-sm:group-[.expanded]:bg-background start-0 end-0 top-12 z-20 grid transition-all duration-300 group-[.expanded]:opacity-100 group-[.not-top]:rounded-xl max-md:border-b max-sm:absolute max-sm:pt-0 max-sm:pb-4 max-sm:opacity-0 max-sm:group-[.not-top]:border max-sm:group-[.not-top]:px-4 max-sm:group-[.not-top]:pt-2 max-sm:group-[.not-top]:pb-2 sm:grid-rows-1 sm:border-0'
        >
          <div
            class='dark:max-sm:group-[.expanded]:bg-muted absolute top-0 -left-4 -z-10 box-content hidden h-full w-[calc(100%+2rem)] bg-white max-md:border-b max-sm:group-[.expanded]:block max-sm:group-[.expanded.not-top]:hidden'
          >
          </div>
          <div
            class='flex flex-col items-center justify-center gap-x-5 gap-y-2 overflow-hidden transition-colors sm:flex-row sm:gap-x-7'
          >
            {
              menuLinks.map((item) => {
                const active = isActive(item.link)
                const external = item.link.startsWith('http')
                return (
                  <a
                    href={item.link}
                    target={external ? '_blank' : undefined}
                    rel={external ? 'noopener noreferrer' : undefined}
                    class:list={[
                      'nav-item hover:text-primary relative w-full flex-none grow py-2 text-center text-base font-medium transition-colors sm:w-fit',
                      active && 'is-active text-primary'
                    ]}
                    aria-current={active ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                )
              })
            }
          </div>
        </div>

        <div
          class='flex items-center gap-x-5 transition-all group-[.not-top]:me-3 sm:group-[.not-top]:me-5'
        >
          <button
            id='toggleDarkMode'
            type='button'
            class='group/dark box-content size-5 rounded-full p-1.5 transition-colors'
          >
            <span class='sr-only'>Dark Theme</span>
            <svg class='system group-hover/dark:text-primary size-5 transition-colors'>
              <use href='/icons/header.svg#ph-desktop'></use>
            </svg>
            <svg class='light group-hover/dark:text-primary hidden size-5 transition-colors'>
              <use href='/icons/header.svg#mingcute-sun-line'></use>
            </svg>
            <svg class='dark group-hover/dark:text-primary hidden size-5 transition-colors'>
              <use href='/icons/header.svg#mingcute-moon-stars-line'></use>
            </svg>
          </button>
          <button
            id='toggleMenu'
            type='button'
            class='rounded-full p-1.5 transition-colors sm:hidden'
            aria-controls='headerExpandContent'
            aria-expanded='false'
          >
            <span class='sr-only'>Menu</span>
            <svg class='size-5'>
              <use href='/icons/header.svg#mingcute-menu-line'></use>
            </svg>
          </button>
        </div>
      </div>
    </nav>
  </header>
</header-component>

<script is:inline data-astro-rerun>
  const toggleDarkModeElement = document.getElementById('toggleDarkMode')
  if (toggleDarkModeElement) {
    toggleDarkModeElement.dataset.theme = localStorage.getItem('theme') || 'system'
  }
</script>
<script>
  import { setTheme, showToast } from '@/utils'

  class Header extends HTMLElement {
    abort?: AbortController

    constructor() {
      super()
    }

    connectedCallback() {
      const signal = (this.abort = new AbortController()).signal
      let preScrollY = window.scrollY
      let ticking = false
      const updateHeader = () => {
        const scrollY = window.scrollY
        this.classList.toggle('not-top', scrollY > 20)
        this.dataset.show = (scrollY < 350 || scrollY < preScrollY).toString()
        preScrollY = scrollY
        ticking = false
      }
      updateHeader()
      window.addEventListener(
        'scroll',
        () => {
          if (ticking) return
          ticking = true
          requestAnimationFrame(updateHeader)
        },
        { passive: true, signal }
      )

      const darkModeBtn = this.querySelector('#toggleDarkMode') as HTMLElement
      darkModeBtn.dataset.theme = localStorage.getItem('theme') || 'system'
      darkModeBtn.addEventListener(
        'click',
        () => {
          const newTheme = setTheme(undefined, true)
          darkModeBtn.dataset.theme = newTheme
          showToast({ message: `Set theme to ${newTheme}` })
        },
        { signal }
      )

      const menu_button = this.querySelector('#toggleMenu') as HTMLButtonElement
      menu_button.addEventListener(
        'click',
        () => {
          menu_button.ariaExpanded = String(this.classList.toggle('expanded'))
        },
        { signal }
      )
    }

    disconnectedCallback() {
      this.abort?.abort()
    }
  }

  if (!customElements.get('header-component')) {
    customElements.define('header-component', Header)
  }
</script>

<style>
  header-component.not-top {
    box-shadow: var(--shadow-soft);
  }

  /* nav active indicator */
  .nav-item::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 0.2rem;
    height: 2px;
    width: 1.25rem;
    margin-left: -0.625rem;
    border-radius: 2px;
    background: hsl(var(--primary));
    transform: scaleX(0);
    transform-origin: center;
    transition:
      transform 220ms cubic-bezier(0.4, 0, 0.2, 1),
      opacity 220ms ease;
    opacity: 0;
  }
  .nav-item:hover::after {
    transform: scaleX(1);
    opacity: 0.55;
  }
  .nav-item.is-active::after {
    transform: scaleX(1);
    opacity: 1;
  }
  @media (max-width: 640px) {
    .nav-item::after {
      display: none;
    }
  }
  header-component[data-show='false']:not(.expanded) {
    transform: translateY(-5rem);
  }

  /* header menu */
  @media (max-width: 640px) {
    #headerExpandContent {
      grid-template-rows: 0fr;
    }
    .expanded #headerExpandContent {
      grid-template-rows: 1fr;
    }
    .expanded.not-top #headerExpandContent {
      box-shadow: var(--shadow-soft);
    }
  }

  /* dark light mode toggle */
  #toggleDarkMode {
    &[data-theme='dark'] {
      & .system {
        display: none;
      }
      & .dark {
        display: block;
      }
    }
    &[data-theme='light'] {
      & .system {
        display: none;
      }
      .light {
        display: block;
      }
    }
  }
</style>
