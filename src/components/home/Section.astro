---
import { cn } from '@/utils'

const { class: className, title, title_position = 'side' } = Astro.props
const title_on_top = title_position === 'top'
---

<section
  class={cn(
    'animate flex flex-col gap-y-5',
    !title_on_top && 'md:flex-row md:gap-y-0',
    className
  )}
>
  <div class={cn('text-xl font-semibold', !title_on_top && 'md:min-w-36')}>
    <h2>{title}</h2>
  </div>
  <div class='flex flex-1 flex-col gap-y-3'>
    <slot />
  </div>
</section>
