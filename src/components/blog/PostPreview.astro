---
import { Image } from 'astro:assets'
import { render, type CollectionEntry } from 'astro:content'
import type { HTMLTag, Polymorphic } from 'astro/types'

import { Button, FormattedDate } from '@/components/user'
import { cn } from '@/utils'

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }> & {
  post: CollectionEntry<'post'>
  detailed?: boolean
  class?: string
  languages?: string[]
}

const { as: Tag = 'div', post, detailed = false, class: className, languages } = Astro.props
const { data, id } = post
const postDate = data.updatedDate ?? data.publishDate
const language_labels: string[] = (languages ?? [data.language.slice(0, 2)]).map(
  (language: string) => language.toUpperCase()
)

const { remarkPluginFrontmatter } = await render(post)
---

<li
  class={cn(
    'group/card relative flex flex-col transition-colors',
    detailed
      ? 'border-border/60 border-b py-4 last:border-b-0 sm:rounded-lg sm:border sm:bg-background sm:px-5 sm:py-5 sm:hover:border-border sm:hover:bg-muted/50'
      : 'card card-hover bg-background ease-in-out',
    className
  )}
>
  <a
    class={cn(
      'group/link w-full flex flex-col transition-all hover:text-primary',
      !detailed && 'sm:flex-row sm:gap-x-4',
      detailed && data.heroImage && 'pe-24 sm:pe-0'
    )}
    href={`/blog/${id}`}
  >
    {
      detailed && data.heroImage && (
        <Image
          src={data.heroImage.src}
          alt={data.heroImage.alt || data.description}
          class='cover-image absolute end-0 top-4 z-0 h-20 w-20 rounded-md object-cover opacity-70 transition-opacity duration-300 group-hover/card:opacity-90 sm:top-0 sm:h-full sm:w-2/3 sm:rounded-lg sm:opacity-45 sm:group-hover/card:opacity-60'
          loading='lazy'
        />
      )
    }

    <div
      class={cn(
        'text-muted-foreground z-10 flex items-center gap-2 py-1 text-xs whitespace-nowrap',
        !detailed && 'sm:min-w-44'
      )}
    >
      <FormattedDate class='min-w-[95px]' date={postDate} />
      <span class='opacity-40' aria-hidden='true'>·</span>
      <span class='flex items-center gap-1.5 font-mono'>
        {
          language_labels.map((language, index) => (
            <>
              {index > 0 && (
                <span class='opacity-40' aria-hidden='true'>
                  ·
                </span>
              )}
              <span>{language}</span>
            </>
          ))
        }
      </span>
    </div>

    <Tag class='z-10 flex-grow'>
      <!-- title -->
      <div class='flex justify-between font-medium'>
        <div>
          {data.draft && <span class='text-red-500'>(Draft) </span>}
          {data.title}
        </div>
        <svg
          xmlns='http://www.w3.org/2000/svg'
          width='16'
          height='16'
          viewBox='0 0 24 24'
          fill='none'
          stroke-width='2.5'
          stroke-linecap='round'
          stroke-linejoin='round'
          class='stroke-muted-foreground group-hover/link:stroke-primary my-1'
          ><line
            x1='5'
            y1='12'
            x2='19'
            y2='12'
            class='translate-x-4 scale-x-0 transition-all duration-300 ease-in-out group-hover/link:translate-x-1 group-hover/link:scale-x-100'
          ></line><polyline
            points='12 5 19 12 12 19'
            class='translate-x-0 transition-all duration-300 ease-in-out group-hover/link:translate-x-1'
          ></polyline></svg
        >
      </div>
      {
        detailed && (
          <>
            {/* desc */}
            <p
              class={cn(
                'text-muted-foreground line-clamp-2 pt-1 text-sm sm:line-clamp-3',
                data.heroImage && 'sm:me-24'
              )}
            >
              {data.description}
            </p>
            <div class='text-muted-foreground flex items-center gap-2 py-1.5 text-sm leading-4 italic sm:py-3'>
              {/* reading time */}
              <span class='flex items-center gap-1'>
                <svg class='size-4'>
                  <use href='/icons/ui.svg#mingcute-time-line' />
                </svg>
                {remarkPluginFrontmatter.minutesRead}
              </span>
            </div>
          </>
        )
      }
    </Tag>
  </a>
  <!-- tags -->
  {
    detailed && data.tags && (
      <ul class='text-muted-foreground mt-1 flex flex-wrap gap-2'>
        {data.tags.slice(0, 2).map((tag: string) => (
          <li>
            <Button title={tag} href={`/tags/${encodeURIComponent(tag)}`} style='pill' />
          </li>
        ))}
      </ul>
    )
  }
</li>

<style>
  @media (min-width: 640px) {
    .cover-image {
      mask-image: linear-gradient(to right, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 1) 100%);
      -ms-mask-image: -ms-linear-gradient(to right, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 1) 100%);
      -webkit-mask-image: -webkit-linear-gradient(
        to right,
        rgba(0, 0, 0, 0) 0%,
        rgba(0, 0, 0, 1) 100%
      );
    }
  }
</style>
