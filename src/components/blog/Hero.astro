---
import { Image } from 'astro:assets'
import { render, type CollectionEntry } from 'astro:content'

import PageInfo from '@/components/pages/PageInfo.astro'
import { Button, FormattedDate } from '@/components/user'

interface LanguageOption {
  href: string
  label: string
  isActive: boolean
}

interface Props {
  content: CollectionEntry<'post'>
  translations?: LanguageOption[]
  commentPath?: string
}

const { content, translations = [], commentPath } = Astro.props
const { id, data } = content

const { remarkPluginFrontmatter } = await render(content)
const lastUpdatedDate = data.updatedDate ?? data.publishDate

const dateTimeOptions: Intl.DateTimeFormatOptions = {
  month: 'short'
}
---

{
  data.heroImage && (
    <div class='hero-image mb-6'>
      {/* @ts-expect-error: image support this type */}
      <Image
        alt={data.heroImage.alt || data.title}
        class='mx-auto block max-h-[33vh] w-auto max-w-full rounded-2xl object-contain shadow-[0_12px_30px_rgba(15,23,42,0.12)]'
        fetchpriority='high'
        loading='eager'
        src={data.heroImage.src}
        data-transparent
      />
    </div>
  )
}

{data.draft ? <span class='text-red-500'>(Draft)</span> : null}

<div class='article-info animate max-lg:mx-auto'>
  <div class='flex flex-wrap gap-x-4 gap-y-2 text-xs leading-6 text-muted-foreground'>
    {/* Article date */}
    <div class='flex items-center gap-1'>
      <svg class='size-5'>
        <use href='/icons/ui.svg#mingcute-calendar-2-line'></use>
      </svg>
      <span class='flex items-center gap-1'>
        <span>Published</span>
        <FormattedDate class='font-sans' date={data.publishDate} dateTimeOptions={dateTimeOptions} />
      </span>
      <span>/</span>
      <span class='flex items-center gap-1'>
        <span>Last Updated</span>
        <FormattedDate class='font-sans' date={lastUpdatedDate} dateTimeOptions={dateTimeOptions} />
      </span>
    </div>
    {/* Times read */}
    <div class='flex items-center gap-1'>
      <svg class='size-5'>
        <use href='/icons/ui.svg#mingcute-time-line'></use>
      </svg>
      {remarkPluginFrontmatter.minutesRead}
    </div>
    {
      // Tags
      !!data.tags?.length && (
        <span class='inline-flex items-center'>
          <svg class='size-5'>
            <use href='/icons/ui.svg#mingcute-hashtag-line' />
          </svg>
          <span class='ms-1'>
            {data.tags.map((tag: string, i: number) => (
              <>
                <a
                  aria-label={`View more posts with the tag ${tag}`}
                  class='text-xs hover:underline hover:underline-offset-4'
                  href={`/tags/${tag}`}
                >
                  {tag}
                </a>
                {i < data.tags.length - 1 ? ' / ' : null}
              </>
            ))}
          </span>
        </span>
      )
    }
  </div>

  <h1 class='mt-4 text-2xl font-medium sm:mb-2 sm:mt-6 sm:text-3xl'>
    {data.title}
  </h1>

  <div class='mt-3 italic'>
    <blockquote class='text-sm text-muted-foreground'><q>{data.description}</q></blockquote>
    {
      !data.draft && (
        <PageInfo
          class='mt-1'
          path={commentPath ?? `/blog/${id}`}
          commentPath={commentPath ?? `/blog/${id}`}
        />
      )
    }
    {
      translations.length > 0 && (
        <div
          class='mt-3 flex flex-wrap items-center gap-2'
          role='group'
          aria-label='Language selection'
        >
          {translations.map((option) => (
            <Button
              key={option.href}
              title={option.label}
              href={option.isActive ? undefined : option.href}
              class={`px-3 py-1.5 text-sm font-semibold tracking-tight shadow-sm transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 ${
                option.isActive
                  ? 'border-primary/70 bg-primary/10 text-primary hover:!bg-primary/15 hover:text-primary'
                  : 'border-border/60 text-muted-foreground hover:border-primary/60 hover:text-primary hover:!bg-primary/5'
              }`}
              aria-current={option.isActive ? 'page' : undefined}
              style='pill'
            />
          ))}
        </div>
      )
    }
  </div>
</div>

{/* Dividing line */}
<div class='mt-4 w-1/2 border-t max-lg:mx-auto sm:mt-6 sm:w-1/3'></div>

<style>
  :global(img[data-transparent]) {
    background-color: transparent;
  }
</style>
