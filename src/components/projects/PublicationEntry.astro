---
import type { ImageMetadata } from 'astro'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'

import { Collapse } from '@/components/user'
import { cn } from '@/utils'

interface Link {
  type: string
  href: string
}

export interface Props {
  class?: string
  name: string
  authors: string
  venue: string
  year: string
  note?: string
  image?: string
  video?: string
  imageAlt?: string
  links: Link[]
  details?: string
  takeaway?: string
  bibtex?: string
  variant?: 'paper' | 'project'
}

const {
  class: className,
  name,
  authors,
  venue,
  year,
  note,
  image: imageName,
  video: videoName,
  imageAlt,
  links,
  details,
  takeaway,
  bibtex,
  variant = 'project'
} = Astro.props

const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/projects/**/*.{jpeg,jpg,png,gif,webp}'
)
const videos = import.meta.glob<{ default: string }>('/src/assets/projects/**/*.{mp4,webm}')
const hflip_video = videoName === 'covers/xl_vla_teaser.mp4'
const is_paper = variant === 'paper'

let imagePath: string | null = null
if (imageName) {
  const resolvedPath = `/src/assets/projects/${imageName}`
  if (images[resolvedPath]) {
    imagePath = resolvedPath
  } else {
    console.warn(
      `Image "${resolvedPath}" does not exist in glob: "src/assets/projects/*.{jpeg,jpg,png,gif,webp}". It will not be displayed.`
    )
  }
}

let videoSrc: string | null = null
if (videoName) {
  const resolvedPath = `/src/assets/projects/${videoName}`
  if (videos[resolvedPath]) {
    videoSrc = (await videos[resolvedPath]!()).default
  } else {
    console.warn(
      `Video "${resolvedPath}" does not exist in glob: "src/assets/projects/*.{mp4,webm}". It will not be displayed.`
    )
  }
}

const icon_name_by_link_type: Record<string, string> = {
  github: 'github',
  huggingface: 'huggingface',
  youtube: 'youtube_bw',
  rerun: 'rerun',
  x: 'x'
}

const sprite_id_by_link_type: Record<string, string> = {
  site: 'mingcute-earth-2-line',
  doc: 'mingcute-document-3-line',
  release: 'mingcute-package-2-line',
  arxiv: 'mingcute-arxiv-2-line',
  slide: 'mingcute-slide-2-line',
  video: 'mingcute-video-2-line'
}

const link_label_by_type: Record<string, string> = {
  site: 'WEBSITE',
  arxiv: 'PAPER',
  github: 'Code',
  huggingface: 'Data',
  rerun: 'Rerun',
  x: 'X Post',
  youtube: 'Video',
  video: 'Video',
  doc: 'Docs',
  release: 'Release',
  slide: 'Slides'
}

const authors_html = authors.replace(/^<br\s*\/?>/i, '')
const has_media = !!(videoSrc || imagePath)
---

{
  is_paper ? (
    <article
      class={cn(
        'publication-entry--paper border-t border-border/70 py-5 first:border-t-0',
        className
      )}
    >
      <div class={cn('grid gap-4 md:gap-5', has_media && 'md:grid-cols-[minmax(180px,240px)_1fr]')}>
        {has_media && (
          <div class='publication-entry__paper_media aspect-video overflow-hidden rounded-md border border-border/60 bg-muted md:aspect-[16/9]'>
            {videoSrc ? (
              <video
                class='publication-entry__paper_video m-0 block h-full w-full object-cover opacity-0 transition-opacity duration-500 data-[ready=true]:opacity-100'
                data-inline-video
                data-ready='false'
                data-src={videoSrc}
                muted
                playsinline
                loop
                preload='none'
                aria-hidden='true'
                tabindex='-1'
              />
            ) : (
              imagePath && (
                <Image
                  class='m-0 block h-full w-full object-cover'
                  src={images[imagePath]!()}
                  widths={[320, 480, 720]}
                  sizes='(max-width: 768px) 100vw, (max-width: 1024px) 300px, 360px'
                  quality={60}
                  alt={imageAlt || name}
                  loading='lazy'
                />
              )
            )}
          </div>
        )}
        <div class='min-w-0'>
          {(venue || year || note) && (
            <p class='publication-entry__meta mb-2 mt-0'>
              {venue && (
                <span class='publication-entry__meta_venue'>
                  <i>{venue}</i>
                </span>
              )}
              {venue && year && <span class='publication-entry__meta_dot'>·</span>}
              {year && <span class='publication-entry__meta_year'>{year}</span>}
              {(venue || year) && note && <span class='publication-entry__meta_dot'>·</span>}
              {note && (
                <span class='publication-entry__meta_tag'>
                  <i>{note}</i>
                </span>
              )}
            </p>
          )}
          <h3 class='my-0 text-base font-semibold leading-snug text-foreground sm:text-lg'>
            {name}
          </h3>
          <p class='mb-0 mt-2 text-sm leading-6 text-muted-foreground' set:html={authors_html} />
          {takeaway && (
            <p class='mb-0 mt-3 text-sm leading-6 text-muted-foreground'>
              <strong class='font-semibold text-foreground'>Takeaway:</strong>{' '}{takeaway}
            </p>
          )}
          {(links?.length > 0 || bibtex) && (
            <div class='mt-3 flex flex-wrap gap-x-3 gap-y-1.5'>
              {links.map((link) => (
                <a
                  href={link.href}
                  class='text-xs font-medium uppercase tracking-[0.08em] text-muted-foreground no-underline transition-colors hover:text-primary hover:no-underline'
                  target='_blank'
                  rel='noopener noreferrer'
                >
                  {link_label_by_type[link.type] || link.type}
                </a>
              ))}
              {bibtex && (
                <button
                  type='button'
                  class='publication-entry__bibtex_button text-xs font-medium uppercase tracking-[0.08em] text-muted-foreground transition-colors hover:text-primary'
                  aria-expanded='false'
                  data-bibtex-toggle
                >
                  BibTeX
                </button>
              )}
            </div>
          )}
          {bibtex && <pre class='publication-entry__bibtex_pre mt-3' hidden set:text={bibtex} />}
        </div>
      </div>
    </article>
  ) : (
    <article class={cn('relative overflow-hidden rounded-md border border-border/60', className)}>
      {videoSrc ? (
        <div class='publication-entry__video_wrap pointer-events-none absolute inset-0 z-0 overflow-hidden'>
          <video
            class='publication-entry__video absolute top-0 m-0 block opacity-0 transition-opacity duration-500 data-[ready=true]:opacity-90'
            data-bg-video
            data-ready='false'
            data-hflip={hflip_video ? 'true' : undefined}
            data-src={videoSrc}
            muted
            playsinline
            loop
            preload='none'
            aria-hidden='true'
            tabindex='-1'
          />
        </div>
      ) : (
        imagePath && (
          <Image
            class='publication-entry__image absolute end-0 z-0 m-0 h-full object-cover opacity-90'
            src={images[imagePath]!()}
            widths={[240, 400, 800]}
            sizes='(max-width: 768px) 67vw, 400px'
            quality={55}
            alt={imageAlt || name}
            loading='lazy'
          />
        )
      )}
      <div class='relative z-10 flex flex-col gap-y-0.5 px-3 pb-2 pt-4'>
        <div class='text-lg font-medium text-foreground no-underline transition-colors sm:text-xl'>
          {name}
        </div>

        <p class='mb-[1.25em] mt-0 text-sm text-muted-foreground' set:html={authors} />
        {details && <p class='mb-[1.25em] mt-0 text-sm text-muted-foreground' set:html={details} />}
        {(venue || year || note) && (
          <p class='publication-entry__meta mb-[1.25em] mt-0'>
            {venue && (
              <span class='publication-entry__meta_venue'>
                <i>{venue}</i>
              </span>
            )}
            {venue && note && <span class='publication-entry__meta_dot'>·</span>}
            {note && (
              <span class='publication-entry__meta_tag'>
                <i>{note}</i>
              </span>
            )}
            {(venue || note) && year && <span class='publication-entry__meta_dot'>·</span>}
            {year && <span class='publication-entry__meta_year'>{year}</span>}
          </p>
        )}
        {takeaway && (
          <Collapse title='Takeaway' class='mb-[1.25em] mt-0 w-full sm:w-1/2' transparent={true}>
            <p class='m-0 text-sm leading-6 text-muted-foreground'>{takeaway}</p>
          </Collapse>
        )}
        {(links?.length > 0 || bibtex) && (
          <div class='mt-0.5 flex flex-row items-center gap-x-2 sm:gap-x-2.5'>
            {links.map((link) => {
              const iconName = icon_name_by_link_type[link.type]
              if (iconName)
                return (
                  <a
                    href={link.href}
                    class='p-0 text-muted-foreground no-underline transition-colors hover:text-primary hover:no-underline'
                    aria-label={link.type}
                    target='_blank'
                    rel='noopener noreferrer'
                  >
                    <Icon is:inline name={iconName} class='block size-4 sm:size-5' />
                  </a>
                )

              const spriteId = sprite_id_by_link_type[link.type]
              if (spriteId)
                return (
                  <a
                    href={link.href}
                    class='p-0 text-muted-foreground no-underline transition-colors hover:text-primary hover:no-underline'
                    aria-label={link.type}
                    target='_blank'
                    rel='noopener noreferrer'
                  >
                    <svg class='size-4 sm:size-5'>
                      <use href={`/icons/project.svg#${spriteId}`} />
                    </svg>
                  </a>
                )

              return null
            })}
            {bibtex && (
              <button
                type='button'
                class='publication-entry__bibtex_button text-xs font-medium uppercase tracking-[0.08em] text-muted-foreground transition-colors hover:text-primary'
                aria-expanded='false'
                data-bibtex-toggle
              >
                BibTeX
              </button>
            )}
          </div>
        )}
        {bibtex && (
          <pre
            class='publication-entry__bibtex_pre mt-3 max-w-full sm:max-w-[70%]'
            hidden
            set:text={bibtex}
          />
        )}
      </div>
    </article>
  )
}

<script>
  const w = window as Window & { __publicationEntryBgVideoInit?: boolean }
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
  const saveData = (navigator as Navigator & { connection?: { saveData?: boolean } }).connection
    ?.saveData
  const bgVideos = Array.from(document.querySelectorAll<HTMLVideoElement>('video[data-bg-video]'))
  const inlineVideos = Array.from(
    document.querySelectorAll<HTMLVideoElement>('video[data-inline-video]')
  )
  const videos = [...bgVideos, ...inlineVideos]

  if (!w.__publicationEntryBgVideoInit && !reduceMotion && !saveData && videos.length) {
    w.__publicationEntryBgVideoInit = true
    const onIdle = window.requestIdleCallback || ((cb) => setTimeout(cb, 1))

    onIdle(() => {
      const syncVideoSize = (video: HTMLVideoElement) => {
        const wrap = video.parentElement as HTMLElement
        const height = wrap.clientHeight
        const wrapWidth = wrap.clientWidth
        const width = (height * video.videoWidth) / video.videoHeight
        const hflip = video.dataset.hflip === 'true'
        video.style.height = '100%'
        video.style.width = `${width}px`
        if (width > wrapWidth) {
          video.style.left = '50%'
          video.style.right = 'auto'
          video.style.transform = hflip ? 'translateX(-50%) scaleX(-1)' : 'translateX(-50%)'
        } else {
          video.style.left = 'auto'
          video.style.right = '0'
          video.style.transform = hflip ? 'scaleX(-1)' : 'none'
        }
      }

      const ro = new ResizeObserver((entries) => {
        entries.forEach((entry) => {
          const video = entry.target.querySelector(
            'video[data-bg-video]'
          ) as HTMLVideoElement | null
          if (video?.videoWidth) syncVideoSize(video)
        })
      })

      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const video = entry.target as HTMLVideoElement

          if (entry.isIntersecting) {
            if (!video.src) {
              video.src = video.dataset.src!
              if (video.matches('video[data-bg-video]')) {
                video.addEventListener('loadedmetadata', () => syncVideoSize(video), { once: true })
              }
              video.addEventListener('loadeddata', () => (video.dataset.ready = 'true'), {
                once: true
              })
            }
            video.play()
          } else {
            video.pause()
          }
        })
      })

      bgVideos.forEach((video) => {
        ro.observe(video.closest('article') as HTMLElement)
        if (video.videoWidth) syncVideoSize(video)
        io.observe(video)
      })

      inlineVideos.forEach((video) => io.observe(video))
    })
  }

  document.querySelectorAll<HTMLButtonElement>('[data-bibtex-toggle]').forEach((button) => {
    button.addEventListener('click', () => {
      const panel = button.parentElement!.nextElementSibling! as HTMLPreElement
      panel.hidden = !panel.hidden
      button.ariaExpanded = String(!panel.hidden)
    })
  })
</script>

<style>
  .publication-entry__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem 0.5rem;
    font-size: 0.75rem;
    color: hsl(var(--muted-foreground));
  }

  .publication-entry__meta_venue {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .publication-entry__meta_dot {
    opacity: 0.45;
  }

  .publication-entry__meta_year {
    font-size: inherit;
  }

  .publication-entry__meta_tag {
    padding: 0;
    color: hsl(29 38% 42%);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .dark .publication-entry__meta_tag {
    color: hsl(31 58% 72%);
  }

  .publication-entry__bibtex_button {
    cursor: pointer;
    border: 0;
    background: transparent;
    padding: 0;
  }

  .publication-entry__bibtex_pre {
    max-height: 18rem;
    overflow: auto;
    border-radius: 0.375rem;
    border: 1px solid hsl(var(--border) / 0.7);
    background: hsl(var(--muted) / 0.45);
    padding: 0.75rem;
    color: hsl(var(--muted-foreground));
    font-size: 0.72rem;
    line-height: 1.45;
  }

  .publication-entry__image {
    width: 72%;
    mask-image: linear-gradient(to right, transparent 0%, black 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 100%);
  }

  .publication-entry__video {
    mask-image: linear-gradient(to right, transparent 0%, black 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 100%);
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .publication-entry__video[data-hflip='true'] {
    mask-image: linear-gradient(to left, transparent 0%, black 100%);
    -webkit-mask-image: linear-gradient(to left, transparent 0%, black 100%);
  }

  @media (max-aspect-ratio: 1 / 1) {
    .publication-entry__image {
      width: 100%;
      mask-image: linear-gradient(to right, transparent 0%, black 100%);
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 100%);
    }
  }

  @media (min-width: 640px) {
    .publication-entry__meta_tag {
      font-size: 0.78rem;
    }
  }
</style>
