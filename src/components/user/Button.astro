---
import { cn } from '@/utils'

const { as: Tag = 'a', class: className, title, href, style = 'button', ...props } = Astro.props
const isTextArrow = style === 'ahead' || style === 'previous'
---

<Tag
  class={cn(
    'group/button inline-flex items-center gap-x-1 text-sm transition-colors',
    isTextArrow
      ? 'w-fit gap-2 font-medium text-foreground hover:text-primary'
      : 'rounded-md border border-border/70 px-2 py-1 text-muted-foreground hover:border-border hover:bg-muted/60',
    className,
    Tag === 'a' && !href && 'cursor-default',
    style === 'pill' && 'rounded-md'
  )}
  href={href}
  {...props}
>
  <slot name='before'>
    {
      style === 'previous' && (
        <span class='inline-flex h-4 w-5 shrink-0 items-center justify-center overflow-hidden'>
          <svg
            xmlns='http://www.w3.org/2000/svg'
            width='16'
            height='16'
            viewBox='0 0 24 24'
            fill='none'
            stroke-width='2.5'
            stroke-linecap='round'
            stroke-linejoin='round'
            class='stroke-current transition-transform duration-300 will-change-transform group-hover/button:-translate-x-1'
          >
            <line x1='19' y1='12' x2='5' y2='12' />
            <polyline points='12 19 5 12 12 5' />
          </svg>
        </span>
      )
    }
  </slot>
  <slot>
    {
      title &&
        (isTextArrow ? (
          <span class='relative after:absolute after:-bottom-1 after:left-0 after:h-px after:w-full after:origin-left after:scale-x-0 after:bg-current after:transition-transform after:duration-300 group-hover/button:after:scale-x-100'>
            {title}
          </span>
        ) : (
          <p class='my-0'>{title}</p>
        ))
    }
  </slot>
  <slot name='after'>
    {
      style === 'ahead' && (
        <span class='inline-flex h-4 w-5 shrink-0 items-center justify-center overflow-hidden'>
          <svg
            xmlns='http://www.w3.org/2000/svg'
            width='16'
            height='16'
            viewBox='0 0 24 24'
            fill='none'
            stroke-width='2.5'
            stroke-linecap='round'
            stroke-linejoin='round'
            class='stroke-current transition-transform duration-300 will-change-transform group-hover/button:translate-x-1'
          >
            <line x1='5' y1='12' x2='19' y2='12' />
            <polyline points='12 5 19 12 12 19' />
          </svg>
        </span>
      )
    }
  </slot>
</Tag>
