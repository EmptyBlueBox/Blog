---
import { Image } from 'astro:assets'

import { cn } from '@/utils'

const {
  as: Tag = 'div',
  class: className,
  href,
  heading,
  subheading,
  date,
  location,
  image,
  altText,
  isLCP = false
} = Astro.props
---

<Tag
  class={cn(
    'not-prose relative isolate block overflow-hidden rounded-md border border-border/60 px-5 py-3',
    href && 'transition-colors hover:border-border hover:bg-muted/50',
    className
  )}
  href={href}
  target={href ? '_blank' : undefined}
  rel={href ? 'noopener noreferrer' : undefined}
>
  {
    image && (
      <Image
        src={image}
        widths={[189, 280, 360]}
        sizes='(max-width: 768px) 189px, (max-width: 1200px) 280px, 189px'
        quality={55}
        alt={altText ?? heading}
        class='pointer-events-none absolute inset-y-0 end-0 z-0 m-0 h-full w-1/2 object-cover object-center opacity-30 [mask-image:linear-gradient(to_left,black_45%,transparent)]'
        priority={isLCP}
      />
    )
  }
  <div class='relative z-10 flex flex-col gap-y-1.5'>
    <div class='flex flex-col gap-y-0.5'>
      <h2 class='text-lg font-medium'>{heading}</h2>
      {subheading && <p class='text-muted-foreground'>{subheading}</p>}
      {date && <p class='text-muted-foreground'>{date}</p>}
      {location && <p class='text-muted-foreground'>{location}</p>}
    </div>
    <slot />
  </div>
</Tag>
