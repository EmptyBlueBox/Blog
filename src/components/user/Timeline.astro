---
import { cn } from '@/utils'

interface Props {
  class?: string
  events: {
    date: string
    content: string
  }[]
}

const { class: className, events, ...props } = Astro.props
---

<div class={cn('not-prose', className)} {...props}>
  <ol class='m-0 list-none ps-0'>
    {
      events.map((event) => (
        <li class='border-border/60 grid gap-2 border-t py-5 first:border-t-0 sm:grid-cols-[10rem_minmax(0,1fr)] sm:gap-6'>
          <div class='flex h-6 items-center gap-3'>
            <span class='bg-primary size-1.5 shrink-0 rounded-full' />
            <time class='text-primary font-mono text-xs leading-6 font-medium tracking-wide'>
              {event.date}
            </time>
          </div>
          <div class='timeline-content min-w-0 text-sm leading-6'>
            <Fragment set:html={event.content} />
          </div>
        </li>
      ))
    }
  </ol>
</div>

<style>
  .timeline-content :global(a) {
    color: hsl(var(--foreground));
    text-decoration: underline;
    text-decoration-color: hsl(var(--border));
    text-underline-offset: 0.2em;
  }

  .timeline-content :global(a:hover) {
    color: hsl(var(--primary));
  }
</style>
