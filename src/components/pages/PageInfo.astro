---
import { cn } from '@/utils'

const { class: className, commentPath, hideComment, path, ...props } = Astro.props
---

<div data-page-info class={cn('text-base text-sm text-muted-foreground', className)} {...props}>
  <span class='waline-pageview-count' data-counter-label='Post views' data-path={path}></span> views
  {
    !hideComment && (
      <a href='#waline'>
        | <span
          class='waline-comment-count'
          data-counter-label='Post comments'
          data-path={commentPath ?? path}
        /> comments
      </a>
    )
  }
</div>

<script>
  import { initPostWalineCounters } from '@/utils/pageview'

  document.querySelectorAll('[data-page-info]').forEach((root) => {
    const pageviewEl = root.querySelector('.waline-pageview-count')
    const commentEl = root.querySelector('.waline-comment-count')
    const pageviewPath = pageviewEl?.getAttribute('data-path') || window.location.pathname
    initPostWalineCounters(pageviewPath, commentEl?.getAttribute('data-path') || pageviewPath, !!commentEl)
  })
</script>
