---
import { cn } from '@/utils'

const { class: className, commentPath, hideComment, path, ...props } = Astro.props
---

<div class={cn('text-base text-sm text-muted-foreground', className)} {...props}>
  <span class='waline-pageview-count' data-counter-label='Post views' data-path={path}></span> views
  {
    !hideComment && (
      <a href='#waline'>
        | <span
          class='waline-comment-count'
          data-counter-label='Post comments'
          data-path={commentPath ?? path}
        /> comments
      </a>
    )
  }
</div>

<script is:inline define:vars={{ commentPath, path, hideComment }}>
  import { initPostWalineCounters } from '@/utils/pageview'

  const safePageviewPath = typeof path === 'string' && path.length > 0 ? path : window.location.pathname
  const safeCommentPath = typeof commentPath === 'string' && commentPath.length > 0
    ? commentPath
    : safePageviewPath
  const shouldCountComment = hideComment !== true

  initPostWalineCounters(safePageviewPath, safeCommentPath, shouldCountComment)
</script>
