{
  "name": "blog",
  "type": "module",
  "version": "3.1.4",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "astro dev",
    "dev:check": "astro check --watch & astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "new-post": "bun scripts/new_post.js",
    "check": "astro check",
    "format": "prettier --write '**/*.{js,jsx,ts,tsx,astro}'",
    "format:check": "prettier --check '**/*.{js,jsx,ts,tsx,astro}'",
    "lint": "eslint 'src/**/*.{js,ts,jsx,tsx,astro}'",
    "fix": "eslint --fix 'src/**/*.{js,ts,jsx,tsx,astro}' && bun run format",
    "verify": "bun run lint && bun run format:check && bun run build"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "overrides": {
    "path-to-regexp": "6.3.0"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/markdown-remark": "7.2.1",
    "@astrojs/mdx": "7.0.2",
    "@astrojs/rss": "4.0.19",
    "@astrojs/sitemap": "3.7.3",
    "@astrojs/vercel": "11.0.2",
    "@rerun-io/web-viewer": "^0.34.1",
    "@tailwindcss/vite": "^4.3.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@waline/client": "^3.15.2",
    "astro": "7.0.6",
    "astro-icon": "1.1.5",
    "caniuse-lite": "^1.0.30001793",
    "hastscript": "^9.0.0",
    "katex": "^0.17.0",
    "reading-time": "^1.5.0",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tailwindcss/typography": "^0.5.20",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shiki": "^4.0.2",
    "unified": "^11.0.5",
    "typescript-eslint": "^8.63.0"
  }
}
